---
layout: base.njk
title: VPNHUB Tutorials
description: Step-by-step VPN tutorials, setup guides, privacy lessons, and server tutorials.
permalink: /tutorials/
---

<main class="tutorials-page">

  <section class="tutorials-hero">
    <div class="tutorials-hero-inner">

      <span class="tutorials-badge">
        More VPN Guides • Setup Help • Troubleshooting
      </span>

      <h1>
        More VPN Tutorials,
        <span>Step by Step</span>
      </h1>

      <p>
        Browse all remaining VPNHUB tutorials. Homepage tutorials are hidden here
        so users can explore the rest of your VPN guides.
      </p>

    </div>
  </section>

  <section class="tutorials-section">
    <div class="tutorials-inner">

      <div class="section-heading">
        <h2>All Other Tutorials</h2>
        <p>These tutorials are not currently shown on the homepage.</p>
      </div>

      {% if collections.regularTutorials.length %}
      <div class="tutorial-grid">

        {% for post in collections.regularTutorials %}
        <article class="tutorial-card">

          {% if post.data.image %}
          <a href="{{ post.url }}" class="tutorial-image-wrap">
            <img src="{{ post.data.image }}" alt="{{ post.data.title }}">
          </a>
          {% endif %}

          <div class="tutorial-card-body">

            <div class="tutorial-meta-row">
              <span class="tutorial-category">
                {{ post.data.category or "VPN Tutorial" }}
              </span>

              <span class="tutorial-time">
                ◷ {{ post.data.readTime or "5 min read" }}
              </span>
            </div>

            <h3>
              <a href="{{ post.url }}">
                {{ post.data.title }}
              </a>
            </h3>

            {% if post.data.description %}
            <p>
              {{ post.data.description }}
            </p>
            {% endif %}

            <a href="{{ post.url }}" class="read-more">
              Open Tutorial →
            </a>

          </div>

        </article>
        {% endfor %}

      </div>
      {% else %}

      <div class="empty-state">
        <h3>No other tutorials found</h3>
        <p>
          Add more posts with <code>tags: posts</code>. The first 3 homepage tutorials are hidden from this page.
        </p>
      </div>

      {% endif %}

    </div>
  </section>

</main>

<style>
.tutorials-page{
  min-height:100vh;
  color:var(--text-main);
  background:
    radial-gradient(circle at 16% 12%, rgba(168,85,247,.26), transparent 28%),
    radial-gradient(circle at 88% 70%, rgba(37,99,235,.24), transparent 34%),
    linear-gradient(135deg,var(--site-bg) 0%,var(--site-bg-2) 46%,var(--site-bg-3) 100%);
}

.tutorials-hero{
  padding:88px 20px 66px;
  text-align:center;
}

.tutorials-hero-inner{
  max-width:920px;
  margin:0 auto;
}

.tutorials-badge{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:10px 24px;
  margin-bottom:30px;
  border-radius:999px;
  border:1px solid var(--card-border);
  background:rgba(168,85,247,.16);
  color:var(--purple-soft);
  font-size:.95rem;
}

.tutorials-hero h1{
  margin:0 0 22px;
  color:var(--text-main);
  font-size:3.7rem;
  line-height:1.08;
  font-weight:950;
  letter-spacing:-.05em;
}

.tutorials-hero h1 span{
  color:var(--purple);
}

.tutorials-hero p{
  max-width:760px;
  margin:0 auto;
  color:var(--text-muted);
  font-size:1.15rem;
  line-height:1.75;
}

.tutorials-section{
  padding:52px 20px 110px;
}

.tutorials-inner{
  max-width:1160px;
  margin:0 auto;
}

.section-heading{
  margin-bottom:38px;
  text-align:center;
}

.section-heading h2{
  margin:0 0 12px;
  color:var(--text-main);
  font-size:2.1rem;
  line-height:1.15;
  font-weight:950;
  letter-spacing:-.035em;
}

.section-heading p{
  margin:0;
  color:var(--text-muted);
  font-size:1.02rem;
}

.tutorial-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:28px;
}

.tutorial-card{
  overflow:hidden;
  border-radius:18px;
  background:var(--card-bg);
  border:1px solid var(--card-border);
  box-shadow:var(--shadow);
  backdrop-filter:blur(22px) saturate(180%);
  -webkit-backdrop-filter:blur(22px) saturate(180%);
  transition:.25s ease;
}

.tutorial-card:hover{
  transform:translateY(-7px);
}

.tutorial-image-wrap{
  display:block;
  overflow:hidden;
}

.tutorial-card img{
  display:block;
  width:100%;
  height:210px;
  object-fit:cover;
  transition:.35s ease;
}

.tutorial-card:hover img{
  transform:scale(1.04);
}

.tutorial-card-body{
  padding:24px;
}

.tutorial-meta-row{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:14px;
  margin-bottom:18px;
}

.tutorial-category{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:6px 12px;
  border-radius:999px;
  background:rgba(124,58,237,.42);
  color:#d8b4fe;
  font-size:.74rem;
  font-weight:900;
}

body.light-mode .tutorial-category{
  color:#7c3aed;
  background:rgba(124,58,237,.12);
}

.tutorial-time{
  color:var(--text-muted);
  font-size:.78rem;
  white-space:nowrap;
}

.tutorial-card h3{
  margin:0 0 14px;
  font-size:1.25rem;
  line-height:1.35;
  font-weight:950;
}

.tutorial-card h3 a{
  color:var(--text-main);
  text-decoration:none;
}

.tutorial-card h3 a:hover{
  color:var(--purple-soft);
}

.tutorial-card p{
  margin:0 0 20px;
  color:var(--text-muted);
  font-size:.94rem;
  line-height:1.65;
}

.read-more{
  color:var(--purple-soft);
  text-decoration:none;
  font-size:.92rem;
  font-weight:900;
}

.empty-state{
  max-width:620px;
  margin:0 auto;
  padding:34px;
  border-radius:20px;
  text-align:center;
  background:var(--card-bg);
  border:1px solid var(--card-border);
  box-shadow:var(--shadow);
}

.empty-state h3{
  margin:0 0 12px;
  color:var(--text-main);
  font-size:1.45rem;
}

.empty-state p{
  margin:0;
  color:var(--text-muted);
  line-height:1.7;
}

.empty-state code{
  padding:3px 7px;
  border-radius:7px;
  background:rgba(15,23,42,.75);
  color:#d8b4fe;
}

@media(max-width:1000px){
  .tutorial-grid{
    grid-template-columns:repeat(2,1fr);
  }

  .tutorials-hero h1{
    font-size:3.1rem;
  }
}

@media(max-width:768px){
  .tutorials-hero{
    padding:56px 16px 42px;
  }

  .tutorials-badge{
    margin-bottom:24px;
    padding:9px 16px;
    font-size:.78rem;
  }

  .tutorials-hero h1{
    font-size:2.2rem;
    line-height:1.14;
  }

  .tutorials-hero p{
    font-size:1rem;
    line-height:1.7;
  }

  .tutorials-section{
    padding:42px 16px 76px;
  }

  .section-heading h2{
    font-size:1.8rem;
  }

  .tutorial-grid{
    grid-template-columns:1fr;
    gap:22px;
  }

  .tutorial-card{
    border-radius:16px;
  }

  .tutorial-card img{
    height:210px;
  }

  .tutorial-card-body{
    padding:22px;
  }
}

@media(max-width:420px){
  .tutorials-hero h1{
    font-size:2rem;
  }

  .tutorial-meta-row{
    align-items:flex-start;
    flex-direction:column;
    gap:10px;
  }

  .tutorial-card img{
    height:190px;
  }
}
</style>
