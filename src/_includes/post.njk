---
layout: base.njk
---

<main class="post-page">

  <article class="post-shell">

    {% if image %}
    <div class="post-cover">
      <img src="{{ image }}" alt="{{ title }}">
    </div>
    {% endif %}

    <div class="post-content-wrap">

      <div class="post-meta-row">
        <span class="post-category">
          {{ category or "VPN Tutorial" }}
        </span>

        <div class="post-meta-right">
          {% if readTime %}
          <span>◷ {{ readTime }}</span>
          {% endif %}

          {% if author %}
          <span>♙ {{ author }}</span>
          {% endif %}
        </div>
      </div>

      <h1>{{ title }}</h1>

      {% if date %}
      <p class="post-date">
        {{ date | readableDate }}
      </p>
      {% endif %}

      {% if description %}
      <p class="post-description">
        {{ description }}
      </p>
      {% endif %}

      {% if difficulty or platform %}
      <div class="post-info-row">
        {% if difficulty %}
        <span>{{ difficulty }}</span>
        {% endif %}

        {% if platform %}
        <span>{{ platform }}</span>
        {% endif %}
      </div>
      {% endif %}

      {% if youtubeId %}
      <div class="video-embed">
        <iframe
          src="https://www.youtube.com/embed/{{ youtubeId }}"
          title="{{ title }}"
          loading="lazy"
          allowfullscreen>
        </iframe>
      </div>
      {% endif %}

      <div class="post-body">
        {{ content | safe }}
      </div>

    </div>

  </article>

</main>

<style>
.post-page{
  min-height:100vh;
  padding:130px 20px 90px;
  color:var(--text-main);
  background:
    radial-gradient(circle at 16% 12%, rgba(168,85,247,.26), transparent 28%),
    radial-gradient(circle at 88% 70%, rgba(37,99,235,.24), transparent 34%),
    linear-gradient(135deg,var(--site-bg) 0%,var(--site-bg-2) 46%,var(--site-bg-3) 100%);
}

.post-shell{
  width:min(900px,100%);
  margin:0 auto;
  overflow:hidden;
  border-radius:22px;
  background:var(--card-bg);
  border:1px solid var(--card-border);
  box-shadow:var(--shadow);
  backdrop-filter:blur(22px) saturate(180%);
  -webkit-backdrop-filter:blur(22px) saturate(180%);
}

.post-cover{
  width:100%;
  overflow:hidden;
  background:rgba(15,23,42,.45);
}

.post-cover img{
  display:block;
  width:100%;
  height:auto;
  max-height:430px;
  object-fit:cover;
}

.post-content-wrap{
  padding:34px;
}

.post-meta-row{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:18px;
  margin-bottom:24px;
}

.post-category{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:7px 14px;
  border-radius:999px;
  background:rgba(124,58,237,.42);
  color:#d8b4fe;
  font-size:.78rem;
  font-weight:900;
}

body.light-mode .post-category{
  color:#7c3aed;
  background:rgba(124,58,237,.12);
}

.post-meta-right{
  display:flex;
  align-items:center;
  justify-content:flex-end;
  flex-wrap:wrap;
  gap:16px;
  color:var(--text-muted);
  font-size:.88rem;
}

.post-content-wrap h1{
  margin:0 0 18px;
  color:var(--text-main);
  font-size:2.25rem;
  line-height:1.16;
  font-weight:950;
  letter-spacing:-.04em;
}

.post-date{
  margin:0 0 26px;
  color:var(--text-muted);
  font-size:.98rem;
}

.post-description{
  margin:0 0 28px;
  color:var(--text-muted);
  font-size:1.05rem;
  line-height:1.75;
}

.post-info-row{
  display:flex;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
  margin:0 0 28px;
}

.post-info-row span{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:7px 13px;
  border-radius:999px;
  color:var(--text-main);
  background:rgba(255,255,255,.08);
  border:1px solid var(--card-border);
  font-size:.82rem;
  font-weight:800;
}

body.light-mode .post-info-row span{
  background:rgba(124,58,237,.08);
}

.video-embed{
  width:100%;
  aspect-ratio:16/9;
  margin:30px 0;
  overflow:hidden;
  border-radius:16px;
  background:#0f172a;
  border:1px solid var(--card-border);
  box-shadow:0 18px 45px rgba(0,0,0,.22);
}

.video-embed iframe{
  display:block;
  width:100%;
  height:100%;
  border:0;
}

.post-body{
  color:var(--text-main);
  font-size:1rem;
  line-height:1.8;
}

.post-body h1,
.post-body h2,
.post-body h3,
.post-body h4{
  color:var(--text-main);
  line-height:1.22;
  font-weight:950;
  letter-spacing:-.035em;
}

.post-body h2{
  margin:38px 0 16px;
  font-size:1.75rem;
}

.post-body h3{
  margin:30px 0 12px;
  font-size:1.35rem;
}

.post-body p{
  margin:0 0 18px;
  color:var(--text-muted);
}

.post-body strong{
  color:var(--text-main);
}

.post-body a{
  color:var(--purple-soft);
  font-weight:800;
  text-decoration:none;
}

.post-body a:hover{
  text-decoration:underline;
}

.post-body ul,
.post-body ol{
  margin:0 0 22px;
  padding-left:24px;
  color:var(--text-muted);
}

.post-body li{
  margin-bottom:9px;
}

.post-body img{
  display:block;
  width:100%;
  height:auto;
  margin:28px 0;
  border-radius:16px;
  border:1px solid var(--card-border);
  box-shadow:0 18px 45px rgba(0,0,0,.20);
}

.post-body blockquote{
  margin:28px 0;
  padding:20px 22px;
  border-left:4px solid var(--purple);
  border-radius:14px;
  background:rgba(124,58,237,.12);
  color:var(--text-main);
}

.post-body code{
  padding:3px 7px;
  border-radius:7px;
  background:rgba(15,23,42,.82);
  color:#d8b4fe;
  font-size:.92em;
}

body.light-mode .post-body code{
  background:rgba(124,58,237,.10);
  color:#6d28d9;
}

.post-body pre{
  overflow:auto;
  padding:18px;
  border-radius:16px;
  background:rgba(15,23,42,.92);
  border:1px solid var(--card-border);
}

.post-body pre code{
  padding:0;
  background:transparent;
  color:#e5e7eb;
}

body.light-mode .post-body pre{
  background:rgba(15,23,42,.92);
}

body.light-mode .post-shell{
  background:rgba(255,255,255,.84);
}

body.light-mode .post-cover{
  background:rgba(255,255,255,.35);
}

@media(max-width:768px){
  .post-page{
    padding:112px 16px 70px;
  }

  .post-shell{
    border-radius:18px;
  }

  .post-content-wrap{
    padding:24px 20px;
  }

  .post-meta-row{
    align-items:flex-start;
    flex-direction:column;
    gap:12px;
    margin-bottom:22px;
  }

  .post-meta-right{
    justify-content:flex-start;
    gap:12px;
    font-size:.82rem;
  }

  .post-content-wrap h1{
    font-size:1.85rem;
  }

  .post-description{
    font-size:1rem;
  }

  .post-body{
    font-size:.96rem;
    line-height:1.75;
  }

  .post-body h2{
    font-size:1.45rem;
  }

  .post-body h3{
    font-size:1.2rem;
  }
}

@media(max-width:420px){
  .post-page{
    padding:106px 12px 64px;
  }

  .post-content-wrap{
    padding:22px 18px;
  }

  .post-content-wrap h1{
    font-size:1.65rem;
  }

  .post-category{
    font-size:.72rem;
  }
}
</style>
