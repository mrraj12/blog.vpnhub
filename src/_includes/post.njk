---
layout: base.njk
---

<main class="article-page">

  <section class="article-wrap">

    <a class="back-link" href="/">
      ‹ Back to Home
    </a>

    <article class="article-card">

      {% if image %}
      <img class="article-cover" src="{{ image }}" alt="{{ title }}">
      {% endif %}

      <div class="article-body">

        <div class="article-top">

          {% if category %}
          <span class="article-category">
            {{ category }}
          </span>
          {% endif %}

          <div class="article-meta">
            {% if readTime %}
            <span>◷ {{ readTime }}</span>
            {% endif %}

            {% if author %}
            <span>♙ {{ author }}</span>
            {% endif %}
          </div>

        </div>

        <h1>{{ title }}</h1>

        {% if date %}
        <p class="article-date">
          {{ date | readableDate }}
        </p>
        {% endif %}

        {% if description %}
        <p class="article-description">
          {{ description }}
        </p>
        {% endif %}

        <div class="article-content">
          {{ content | safe }}
        </div>

      </div>

    </article>

  </section>

</main>

<style>
.article-page{
  min-height:100vh;
  color:#ffffff;
  background:
    radial-gradient(circle at 12% 12%, rgba(168,85,247,.22), transparent 28%),
    radial-gradient(circle at 85% 70%, rgba(37,99,235,.26), transparent 34%),
    linear-gradient(135deg,#111827 0%,#4c1d95 46%,#1e3a8a 100%);
}

.article-wrap{
  width:100%;
  max-width:980px;
  margin:0 auto;
  padding:46px 20px 100px;
}

.back-link{
  display:inline-flex;
  align-items:center;
  gap:8px;
  margin-bottom:28px;
  color:#c084fc;
  font-size:1rem;
  font-weight:700;
  text-decoration:none;
}

.back-link:hover{
  color:#d8b4fe;
}

.article-card{
  overflow:hidden;
  border-radius:18px;
  background:rgba(31,41,55,.88);
  border:1px solid rgba(216,180,254,.12);
  box-shadow:
    0 30px 90px rgba(0,0,0,.34),
    inset 0 1px 0 rgba(255,255,255,.06);
  backdrop-filter:blur(24px) saturate(180%);
  -webkit-backdrop-filter:blur(24px) saturate(180%);
}

.article-cover{
  display:block;
  width:100%;
  height:410px;
  object-fit:cover;
}

.article-body{
  padding:34px 36px 40px;
}

.article-top{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:18px;
  margin-bottom:26px;
}

.article-category{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:7px 14px;
  border-radius:999px;
  background:rgba(124,58,237,.42);
  color:#d8b4fe;
  font-size:.82rem;
  font-weight:900;
}

.article-meta{
  display:flex;
  align-items:center;
  gap:18px;
  color:#9ca3af;
  font-size:.92rem;
  white-space:nowrap;
}

.article-body h1{
  max-width:850px;
  margin:0 0 22px;
  color:#ffffff;
  font-size:2.45rem;
  line-height:1.15;
  letter-spacing:-.04em;
  font-weight:950;
}

.article-date{
  margin:0 0 28px;
  color:#cbd5e1;
  font-size:1.05rem;
}

.article-description{
  margin:0 0 28px;
  color:#e5e7eb;
  font-size:1.08rem;
  line-height:1.8;
}

.article-content{
  color:#e5e7eb;
  font-size:1rem;
  line-height:1.75;
}

.article-content h2,
.article-content h3,
.article-content h4{
  color:#ffffff;
  line-height:1.25;
  letter-spacing:-.025em;
}

.article-content h2{
  margin:36px 0 14px;
  font-size:1.85rem;
}

.article-content h3{
  margin:28px 0 12px;
  font-size:1.28rem;
}

.article-content h4{
  margin:24px 0 10px;
  font-size:1.12rem;
}

.article-content p{
  margin:0 0 18px;
  color:#e5e7eb;
}

.article-content strong{
  color:#ffffff;
  font-weight:900;
}

.article-content ul,
.article-content ol{
  margin:0 0 24px;
  padding-left:24px;
}

.article-content li{
  margin-bottom:9px;
  color:#e5e7eb;
}

.article-content a{
  color:#c084fc;
  font-weight:800;
  text-decoration:none;
}

.article-content a:hover{
  text-decoration:underline;
}

/* Images added anywhere inside article text */
.article-content img{
  display:block;
  width:100%;
  max-width:100%;
  height:auto;
  margin:30px auto;
  border-radius:18px;
  border:1px solid rgba(216,180,254,.14);
  box-shadow:
    0 24px 60px rgba(0,0,0,.34),
    inset 0 1px 0 rgba(255,255,255,.08);
}

/* Optional image captions */
.article-content em{
  color:#cbd5e1;
}

/* Video embeds */
.article-content iframe{
  display:block;
  width:100%;
  aspect-ratio:16/9;
  height:auto;
  margin:30px auto;
  border:0;
  border-radius:18px;
  box-shadow:0 24px 60px rgba(0,0,0,.34);
}

.article-content blockquote{
  margin:28px 0;
  padding:20px 22px;
  border-left:4px solid #a855f7;
  border-radius:14px;
  background:rgba(168,85,247,.12);
  color:#e5e7eb;
}

.article-content code{
  padding:3px 7px;
  border-radius:7px;
  background:rgba(15,23,42,.9);
  color:#d8b4fe;
}

.article-content pre{
  overflow:auto;
  padding:20px;
  border-radius:16px;
  background:rgba(15,23,42,.92);
  border:1px solid rgba(255,255,255,.08);
}

.article-content pre code{
  padding:0;
  background:transparent;
}

/* Tablet */
@media(max-width:900px){
  .article-wrap{
    max-width:760px;
  }

  .article-cover{
    height:330px;
  }

  .article-body h1{
    font-size:2.1rem;
  }
}

/* Mobile */
@media(max-width:768px){
  .article-wrap{
    padding:34px 16px 72px;
  }

  .back-link{
    margin-bottom:20px;
    font-size:.95rem;
  }

  .article-card{
    border-radius:16px;
  }

  .article-cover{
    height:230px;
  }

  .article-body{
    padding:24px 20px 28px;
  }

  .article-top{
    align-items:flex-start;
    flex-direction:column;
    gap:14px;
    margin-bottom:22px;
  }

  .article-meta{
    flex-wrap:wrap;
    gap:12px;
    font-size:.84rem;
    white-space:normal;
  }

  .article-body h1{
    font-size:1.72rem;
    line-height:1.2;
    margin-bottom:18px;
  }

  .article-date{
    font-size:.95rem;
    margin-bottom:22px;
  }

  .article-description{
    font-size:.98rem;
  }

  .article-content{
    font-size:.96rem;
    line-height:1.72;
  }

  .article-content h2{
    font-size:1.45rem;
  }

  .article-content h3{
    font-size:1.18rem;
  }

  .article-content img,
  .article-content iframe{
    margin:24px auto;
    border-radius:14px;
  }
}

@media(max-width:420px){
  .article-wrap{
    padding-left:14px;
    padding-right:14px;
  }

  .article-cover{
    height:205px;
  }

  .article-body{
    padding:22px 18px 26px;
  }

  .article-body h1{
    font-size:1.55rem;
  }
}
</style>
