<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{{ title or "VPNHUB" }}</title>

  {% if description %}
  <meta name="description" content="{{ description }}">
  {% endif %}

  <style>
    *{
      box-sizing:border-box;
    }

    html{
      scroll-behavior:smooth;
    }

    body{
      margin:0;
      font-family:Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:#111827;
      color:#ffffff;
    }

    a{
      color:inherit;
    }

    /* =========================
       DESKTOP HEADER
    ========================= */

    .site-header{
      position:sticky;
      top:0;
      z-index:1000;
      background:#111827;
      border-bottom:1px solid rgba(255,255,255,.08);
    }

    .nav-inner{
      max-width:1200px;
      margin:0 auto;
      min-height:78px;
      padding:0 22px;
      display:flex;
      align-items:center;
      justify-content:space-between;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:10px;
      text-decoration:none;
      color:#ffffff;
      font-size:1.55rem;
      font-weight:950;
      letter-spacing:-.035em;
    }

    .brand-icon{
      color:#c084fc;
      font-size:1.45rem;
      line-height:1;
    }

    .desktop-nav{
      display:flex;
      align-items:center;
      gap:30px;
    }

    .desktop-nav a{
      text-decoration:none;
      color:#ffffff;
      font-size:1rem;
      font-weight:800;
      opacity:.9;
      transition:.2s ease;
    }

    .desktop-nav a:hover{
      color:#c084fc;
      opacity:1;
    }

    .mobile-menu-btn{
      display:none;
    }

    .mobile-menu{
      display:none;
    }

    /* =========================
       MOBILE HEADER
    ========================= */

    @media(max-width:768px){
      .site-header{
        position:sticky;
        top:0;
        z-index:1000;
        padding:14px 14px 8px;
        background:linear-gradient(
          180deg,
          #050509 0%,
          rgba(5,5,9,.96) 68%,
          rgba(76,29,149,.18) 100%
        );
        border-bottom:0;
      }

      .nav-inner{
        min-height:76px;
        padding:0 22px;
        border-radius:38px;
        border:1px solid rgba(216,180,254,.14);
        background:rgba(7,7,13,.86);
        box-shadow:
          0 14px 34px rgba(0,0,0,.34),
          inset 0 1px 0 rgba(255,255,255,.04);
        backdrop-filter:blur(14px);
      }

      .brand{
        font-size:1.45rem;
        gap:10px;
      }

      .brand-icon{
        font-size:1.25rem;
        color:#c084fc;
      }

      .desktop-nav{
        display:none;
      }

      .mobile-menu-btn{
        display:flex;
        align-items:center;
        justify-content:center;
        width:48px;
        height:48px;
        border:0;
        border-radius:50%;
        background:transparent;
        color:#ffffff;
        font-size:2rem;
        line-height:1;
        cursor:pointer;
      }

      .mobile-menu-btn.is-open{
        background:rgba(255,255,255,.1);
      }

      .mobile-menu{
        position:absolute;
        top:104px;
        right:20px;
        width:min(68vw,330px);
        padding:34px 42px;
        border-radius:24px;
        border:1px solid rgba(216,180,254,.14);
        background:linear-gradient(135deg,#171b35,#1f2748);
        box-shadow:0 28px 70px rgba(0,0,0,.48);
      }

      .mobile-menu.active{
        display:block;
      }

      .mobile-menu a{
        display:block;
        padding:0 0 34px;
        color:#ffffff;
        text-decoration:none;
        font-size:1.35rem;
        font-weight:800;
        line-height:1.2;
      }

      .mobile-menu a:last-child{
        padding-bottom:0;
      }
    }

    @media(max-width:420px){
      .site-header{
        padding:12px 12px 6px;
      }

      .nav-inner{
        min-height:70px;
        padding:0 18px;
        border-radius:35px;
      }

      .brand{
        font-size:1.28rem;
      }

      .brand-icon{
        font-size:1.1rem;
      }

      .mobile-menu-btn{
        width:44px;
        height:44px;
        font-size:1.85rem;
      }

      .mobile-menu{
        top:96px;
        right:16px;
        width:70vw;
        padding:30px 36px;
      }

      .mobile-menu a{
        font-size:1.25rem;
        padding-bottom:30px;
      }
    }
  </style>
</head>

<body>

  <header class="site-header">
    <div class="nav-inner">

      <a href="/" class="brand" aria-label="VPNHUB Home">
        <span class="brand-icon">◇</span>
        <span>VPNHUB</span>
      </a>

      <!-- Desktop menu -->
      <nav class="desktop-nav" aria-label="Desktop navigation">
        <a href="/tutorials/">Tutorials</a>
        <a href="/videos/">Videos</a>
        <a href="/about/">About</a>
      </nav>

      <!-- Mobile hamburger -->
      <button
        class="mobile-menu-btn"
        id="mobileMenuBtn"
        type="button"
        onclick="toggleMobileMenu()"
        aria-label="Open mobile menu"
        aria-expanded="false"
      >
        <span id="mobileMenuIcon">☰</span>
      </button>

    </div>

    <!-- Mobile dropdown -->
    <nav class="mobile-menu" id="mobileMenu" aria-label="Mobile navigation">
      <a href="/tutorials/">Tutorials</a>
      <a href="/videos/">Videos</a>
      <a href="/about/">About</a>
    </nav>
  </header>

  {{ content | safe }}

  <script>
    function toggleMobileMenu(){
      const menu = document.getElementById("mobileMenu");
      const icon = document.getElementById("mobileMenuIcon");
      const btn = document.getElementById("mobileMenuBtn");

      if(!menu || !icon || !btn) return;

      const isOpen = menu.classList.toggle("active");

      btn.classList.toggle("is-open", isOpen);
      btn.setAttribute("aria-expanded", isOpen ? "true" : "false");
      icon.textContent = isOpen ? "×" : "☰";
    }

    document.addEventListener("click", function(event){
      const menu = document.getElementById("mobileMenu");
      const btn = document.getElementById("mobileMenuBtn");
      const icon = document.getElementById("mobileMenuIcon");

      if(!menu || !btn || !icon) return;

      const clickedInsideMenu = menu.contains(event.target);
      const clickedButton = btn.contains(event.target);

      if(!clickedInsideMenu && !clickedButton){
        menu.classList.remove("active");
        btn.classList.remove("is-open");
        btn.setAttribute("aria-expanded", "false");
        icon.textContent = "☰";
      }
    });
  </script>

</body>
</html>
