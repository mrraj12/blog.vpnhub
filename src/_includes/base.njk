<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{{ title or "VPNHUB" }}</title>

  {% if description %}
  <meta name="description" content="{{ description }}">
  {% endif %}

  <style>
    :root{
      --site-bg:#111827;
      --site-bg-2:#4c1d95;
      --site-bg-3:#1e3a8a;

      --text-main:#ffffff;
      --text-muted:#d1d5db;

      --header-glass:linear-gradient(
        135deg,
        rgba(17,24,39,.76),
        rgba(76,29,149,.38),
        rgba(30,58,138,.34)
      );

      --nav-glass:linear-gradient(
        135deg,
        rgba(8,10,22,.92),
        rgba(17,24,39,.88),
        rgba(24,31,55,.86)
      );

      --card-bg:rgba(31,41,55,.82);
      --card-border:rgba(216,180,254,.18);

      --purple:#a855f7;
      --purple-soft:#d8b4fe;
      --blue:#2563eb;

      --shadow:0 18px 44px rgba(0,0,0,.34);
    }

    body.light-mode{
      --site-bg:#f8fafc;
      --site-bg-2:#f3e8ff;
      --site-bg-3:#dbeafe;

      --text-main:#111827;
      --text-muted:#4b5563;

      --header-glass:linear-gradient(
        135deg,
        rgba(255,255,255,.74),
        rgba(243,232,255,.54),
        rgba(219,234,254,.48)
      );

      --nav-glass:linear-gradient(
        135deg,
        rgba(255,255,255,.88),
        rgba(243,232,255,.72),
        rgba(219,234,254,.62)
      );

      --card-bg:rgba(255,255,255,.82);
      --card-border:rgba(124,58,237,.18);

      --purple:#7c3aed;
      --purple-soft:#7c3aed;
      --blue:#2563eb;

      --shadow:0 18px 44px rgba(15,23,42,.14);
    }

    *{
      box-sizing:border-box;
    }

    html{
      scroll-behavior:smooth;
    }

    body{
      margin:0;
      padding-top:86px;
      font-family:Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at 16% 12%, rgba(168,85,247,.26), transparent 28%),
        radial-gradient(circle at 88% 70%, rgba(37,99,235,.24), transparent 34%),
        linear-gradient(135deg,var(--site-bg) 0%,var(--site-bg-2) 46%,var(--site-bg-3) 100%);
      color:var(--text-main);
      transition:background .3s ease,color .3s ease;
    }

    a{
      color:inherit;
    }

    /* =========================
       DESKTOP FLOATING HEADER
    ========================= */

    .site-header{
      position:fixed;
      top:16px;
      left:0;
      right:0;
      z-index:1000;
      padding:0 18px;
      background:transparent;
      border-bottom:0;
      pointer-events:none;
      transition:transform .28s ease;
    }

    .nav-inner{
      max-width:1200px;
      margin:0 auto;
      min-height:58px;
      padding:0 18px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      position:relative;
      pointer-events:auto;
      border-radius:999px;
      border:1px solid rgba(216,180,254,.16);
      background:
        linear-gradient(
          135deg,
          rgba(8,10,22,.94),
          rgba(17,24,39,.90),
          rgba(24,31,55,.88)
        );
      backdrop-filter:blur(26px) saturate(190%);
      -webkit-backdrop-filter:blur(26px) saturate(190%);
      box-shadow:
        0 18px 50px rgba(0,0,0,.34),
        0 0 0 1px rgba(255,255,255,.03),
        inset 0 1px 0 rgba(255,255,255,.12),
        inset 0 -1px 0 rgba(255,255,255,.04);
      overflow:hidden;
    }

    body.light-mode .nav-inner{
      background:
        linear-gradient(
          135deg,
          rgba(255,255,255,.90),
          rgba(243,232,255,.76),
          rgba(219,234,254,.66)
        );
      box-shadow:
        0 18px 42px rgba(15,23,42,.14),
        0 0 0 1px rgba(124,58,237,.06),
        inset 0 1px 0 rgba(255,255,255,.70),
        inset 0 -1px 0 rgba(255,255,255,.24);
    }

    .nav-inner::before{
      content:"";
      position:absolute;
      inset:0;
      border-radius:inherit;
      pointer-events:none;
      background:
        linear-gradient(
          90deg,
          rgba(255,255,255,.08),
          rgba(255,255,255,.03),
          rgba(255,255,255,.05)
        ),
        radial-gradient(circle at 12% 0%, rgba(216,180,254,.12), transparent 30%);
      opacity:.65;
    }

    body.light-mode .nav-inner::before{
      background:
        linear-gradient(
          90deg,
          rgba(255,255,255,.42),
          rgba(255,255,255,.18),
          rgba(255,255,255,.28)
        ),
        radial-gradient(circle at 12% 0%, rgba(124,58,237,.12), transparent 32%);
      opacity:.7;
    }

    .brand{
      position:relative;
      z-index:1;
      display:flex;
      align-items:center;
      gap:8px;
      text-decoration:none;
      color:var(--text-main);
      font-size:1.2rem;
      font-weight:950;
      letter-spacing:-.035em;
      text-shadow:0 1px 14px rgba(255,255,255,.10);
    }

    .brand-logo{
      width:23px;
      height:23px;
      color:var(--purple-soft);
      display:block;
      flex:0 0 auto;
      filter:drop-shadow(0 0 9px rgba(192,132,252,.42));
    }

    .brand-name{
      line-height:1;
    }

    .desktop-nav{
      position:relative;
      z-index:1;
      display:flex;
      align-items:center;
      gap:8px;
      padding:5px;
      border-radius:999px;
      background:rgba(255,255,255,.06);
      border:1px solid rgba(255,255,255,.08);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.08);
    }

    body.light-mode .desktop-nav{
      background:rgba(255,255,255,.54);
      border-color:rgba(124,58,237,.12);
    }

    .desktop-nav a{
      text-decoration:none;
      color:var(--text-main);
      font-size:.86rem;
      font-weight:800;
      opacity:.92;
      padding:7px 12px;
      border-radius:999px;
      transition:.2s ease;
    }

    .desktop-nav a:hover{
      color:#ffffff;
      background:rgba(168,85,247,.32);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.14),
        0 8px 20px rgba(124,58,237,.22);
      opacity:1;
    }

    .nav-actions{
      position:relative;
      z-index:1;
      display:flex;
      align-items:center;
      gap:8px;
    }

    .theme-toggle{
      width:34px;
      height:34px;
      border:1px solid rgba(255,255,255,.14);
      border-radius:999px;
      background:rgba(255,255,255,.08);
      color:var(--text-main);
      display:flex;
      align-items:center;
      justify-content:center;
      cursor:pointer;
      font-size:.95rem;
      backdrop-filter:blur(16px) saturate(180%);
      -webkit-backdrop-filter:blur(16px) saturate(180%);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.12),
        0 8px 20px rgba(0,0,0,.12);
      transition:.2s ease;
    }

    body.light-mode .theme-toggle{
      background:rgba(255,255,255,.54);
      border-color:rgba(124,58,237,.14);
    }

    .theme-toggle:hover{
      background:rgba(168,85,247,.24);
      transform:translateY(-1px);
    }

    .mobile-menu-btn{
      display:none;
    }

    .mobile-menu{
      display:none;
    }

    /* =========================
       MOBILE OVERLAY HEADER
       Fixed spacing from hero badge
    ========================= */

    @media(max-width:768px){
      body{
        padding-top:84px;
      }

      .site-header{
        position:fixed;
        top:12px;
        left:0;
        right:0;
        z-index:1000;
        padding:0 18px;
        background:transparent;
        pointer-events:none;
        will-change:transform;
      }

      .site-header.mobile-hidden{
        transform:translateY(-125%);
      }

      .nav-inner{
        width:100%;
        min-height:58px;
        padding:0 18px;
        border-radius:999px;
        border:1px solid rgba(216,180,254,.14);
        background:linear-gradient(
          135deg,
          rgba(5,7,16,.88),
          rgba(10,10,22,.80),
          rgba(24,31,55,.76)
        );
        backdrop-filter:blur(28px) saturate(220%);
        -webkit-backdrop-filter:blur(28px) saturate(220%);
        box-shadow:
          0 18px 44px rgba(0,0,0,.34),
          0 0 0 1px rgba(255,255,255,.03),
          inset 0 1px 0 rgba(255,255,255,.12),
          inset 0 -1px 0 rgba(255,255,255,.04);
        overflow:hidden;
      }

      body.light-mode .nav-inner{
        background:linear-gradient(
          135deg,
          rgba(255,255,255,.88),
          rgba(243,232,255,.70),
          rgba(219,234,254,.58)
        );
        box-shadow:
          0 18px 44px rgba(15,23,42,.16),
          0 0 0 1px rgba(124,58,237,.06),
          inset 0 1px 0 rgba(255,255,255,.72),
          inset 0 -1px 0 rgba(255,255,255,.28);
      }

      .nav-inner::before{
        content:"";
        position:absolute;
        inset:0;
        border-radius:inherit;
        pointer-events:none;
        background:
          linear-gradient(
            90deg,
            rgba(255,255,255,.08),
            rgba(255,255,255,.03),
            rgba(255,255,255,.05)
          ),
          radial-gradient(circle at 18% 0%, rgba(216,180,254,.12), transparent 36%);
        opacity:.65;
      }

      .brand{
        position:relative;
        z-index:1;
        font-size:1.06rem;
        gap:8px;
      }

      .brand-logo{
        width:22px;
        height:22px;
      }

      .desktop-nav{
        display:none;
      }

      .nav-actions{
        position:relative;
        z-index:1;
        gap:8px;
      }

      .theme-toggle{
        width:34px;
        height:34px;
        font-size:.9rem;
      }

      .mobile-menu-btn{
        display:flex;
        align-items:center;
        justify-content:center;
        width:34px;
        height:34px;
        border:1px solid rgba(255,255,255,.14);
        border-radius:50%;
        background:rgba(255,255,255,.08);
        color:var(--text-main);
        font-size:1.38rem;
        line-height:1;
        cursor:pointer;
        backdrop-filter:blur(18px) saturate(180%);
        -webkit-backdrop-filter:blur(18px) saturate(180%);
        box-shadow:
          inset 0 1px 0 rgba(255,255,255,.14),
          0 8px 20px rgba(0,0,0,.18);
      }

      .mobile-menu-btn.is-open{
        background:rgba(168,85,247,.22);
        border-color:rgba(216,180,254,.24);
      }

      .mobile-menu{
        position:absolute;
        top:72px;
        right:18px;
        width:min(70vw,300px);
        padding:24px 28px;
        border-radius:24px;
        border:1px solid rgba(216,180,254,.16);
        background:linear-gradient(
          135deg,
          rgba(31,41,55,.86),
          rgba(24,31,55,.78),
          rgba(76,29,149,.36)
        );
        backdrop-filter:blur(30px) saturate(210%);
        -webkit-backdrop-filter:blur(30px) saturate(210%);
        box-shadow:
          0 26px 70px rgba(0,0,0,.48),
          inset 0 1px 0 rgba(255,255,255,.18),
          inset 0 -1px 0 rgba(255,255,255,.06);
        pointer-events:auto;
      }

      body.light-mode .mobile-menu{
        background:linear-gradient(
          135deg,
          rgba(255,255,255,.88),
          rgba(243,232,255,.72),
          rgba(219,234,254,.62)
        );
        box-shadow:
          0 26px 70px rgba(15,23,42,.18),
          inset 0 1px 0 rgba(255,255,255,.75);
      }

      .mobile-menu.active{
        display:block;
      }

      .mobile-menu a{
        display:block;
        padding:0 0 24px;
        color:var(--text-main);
        text-decoration:none;
        font-size:1.04rem;
        font-weight:850;
        line-height:1.2;
        text-shadow:0 1px 14px rgba(0,0,0,.18);
      }

      .mobile-menu a:last-child{
        padding-bottom:0;
      }

      .hero,
      .tutorials-hero,
      .videos-hero,
      .about-hero{
        padding-top:38px !important;
      }
    }

    @media(max-width:420px){
      body{
        padding-top:80px;
      }

      .site-header{
        top:10px;
        padding:0 16px;
      }

      .nav-inner{
        min-height:54px;
        padding:0 16px;
      }

      .brand{
        font-size:1rem;
      }

      .brand-logo{
        width:20px;
        height:20px;
      }

      .theme-toggle,
      .mobile-menu-btn{
        width:32px;
        height:32px;
      }

      .mobile-menu-btn{
        font-size:1.3rem;
      }

      .mobile-menu{
        top:68px;
        right:16px;
        width:72vw;
        padding:24px 26px;
      }

      .mobile-menu a{
        font-size:1.02rem;
        padding-bottom:24px;
      }

      .hero,
      .tutorials-hero,
      .videos-hero,
      .about-hero{
        padding-top:34px !important;
      }
    }
  </style>
</head>

<body>

  <header class="site-header" id="siteHeader">
    <div class="nav-inner">

      <a href="/" class="brand" aria-label="VPNHUB Home">
        <svg
          class="brand-logo"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>
        </svg>

        <span class="brand-name">VPNHUB</span>
      </a>

      <nav class="desktop-nav" aria-label="Desktop navigation">
        <a href="/tutorials/">Tutorials</a>
        <a href="/videos/">Videos</a>
        <a href="/about/">About</a>
      </nav>

      <div class="nav-actions">
        <button
          class="theme-toggle"
          id="themeToggle"
          type="button"
          onclick="toggleTheme()"
          aria-label="Toggle light and dark mode"
        >
          <span id="themeIcon">🌙</span>
        </button>

        <button
          class="mobile-menu-btn"
          id="mobileMenuBtn"
          type="button"
          onclick="toggleMobileMenu()"
          aria-label="Open mobile menu"
          aria-expanded="false"
        >
          <span id="mobileMenuIcon">☰</span>
        </button>
      </div>

    </div>

    <nav class="mobile-menu" id="mobileMenu" aria-label="Mobile navigation">
      <a href="/tutorials/">Tutorials</a>
      <a href="/videos/">Videos</a>
      <a href="/about/">About</a>
    </nav>
  </header>

  {{ content | safe }}

  <script>
    function applyTheme(theme){
      const icon = document.getElementById("themeIcon");

      if(theme === "light"){
        document.body.classList.add("light-mode");
        if(icon) icon.textContent = "☀️";
      }else{
        document.body.classList.remove("light-mode");
        if(icon) icon.textContent = "🌙";
      }
    }

    function toggleTheme(){
      const currentTheme = localStorage.getItem("vpnhub-theme") || "dark";
      const nextTheme = currentTheme === "dark" ? "light" : "dark";

      localStorage.setItem("vpnhub-theme", nextTheme);
      applyTheme(nextTheme);
    }

    function toggleMobileMenu(){
      const menu = document.getElementById("mobileMenu");
      const icon = document.getElementById("mobileMenuIcon");
      const btn = document.getElementById("mobileMenuBtn");
      const header = document.getElementById("siteHeader");

      if(!menu || !icon || !btn) return;

      const isOpen = menu.classList.toggle("active");

      btn.classList.toggle("is-open", isOpen);
      btn.setAttribute("aria-expanded", isOpen ? "true" : "false");
      icon.textContent = isOpen ? "×" : "☰";

      if(header && isOpen){
        header.classList.remove("mobile-hidden");
      }
    }

    function closeMobileMenu(){
      const menu = document.getElementById("mobileMenu");
      const icon = document.getElementById("mobileMenuIcon");
      const btn = document.getElementById("mobileMenuBtn");

      if(!menu || !icon || !btn) return;

      menu.classList.remove("active");
      btn.classList.remove("is-open");
      btn.setAttribute("aria-expanded", "false");
      icon.textContent = "☰";
    }

    document.addEventListener("DOMContentLoaded", function(){
      const savedTheme = localStorage.getItem("vpnhub-theme") || "dark";
      applyTheme(savedTheme);
    });

    document.addEventListener("click", function(event){
      const menu = document.getElementById("mobileMenu");
      const btn = document.getElementById("mobileMenuBtn");

      if(!menu || !btn) return;

      const clickedInsideMenu = menu.contains(event.target);
      const clickedButton = btn.contains(event.target);

      if(!clickedInsideMenu && !clickedButton){
        closeMobileMenu();
      }
    });

    let lastScrollY = window.scrollY;
    let ticking = false;

    function handleMobileHeaderScroll(){
      const header = document.getElementById("siteHeader");
      const menu = document.getElementById("mobileMenu");

      if(!header) return;

      const isMobile = window.matchMedia("(max-width: 768px)").matches;

      if(!isMobile){
        header.classList.remove("mobile-hidden");
        return;
      }

      const currentScrollY = window.scrollY;
      const menuIsOpen = menu && menu.classList.contains("active");

      if(menuIsOpen){
        header.classList.remove("mobile-hidden");
        lastScrollY = currentScrollY;
        return;
      }

      if(currentScrollY < 20){
        header.classList.remove("mobile-hidden");
      }else if(currentScrollY > lastScrollY && currentScrollY > 80){
        header.classList.add("mobile-hidden");
      }else if(currentScrollY < lastScrollY){
        header.classList.remove("mobile-hidden");
      }

      lastScrollY = currentScrollY;
    }

    window.addEventListener("scroll", function(){
      if(!ticking){
        window.requestAnimationFrame(function(){
          handleMobileHeaderScroll();
          ticking = false;
        });

        ticking = true;
      }
    }, { passive:true });

    window.addEventListener("resize", function(){
      const header = document.getElementById("siteHeader");

      if(window.matchMedia("(min-width: 769px)").matches){
        if(header) header.classList.remove("mobile-hidden");
        closeMobileMenu();
      }
    });
  </script>

</body>
</html>
