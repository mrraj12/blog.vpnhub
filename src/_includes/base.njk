<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{{ title or "VPNHUB" }}</title>

  {% if description %}
  <meta name="description" content="{{ description }}">
  {% endif %}

  <style>
    :root{
      --page-bg:
        radial-gradient(circle at 16% 12%, rgba(168,85,247,.26), transparent 28%),
        radial-gradient(circle at 88% 70%, rgba(37,99,235,.24), transparent 34%),
        linear-gradient(135deg,#111827 0%,#4c1d95 46%,#1e3a8a 100%);

      --header-bg:
        linear-gradient(
          135deg,
          rgba(17,24,39,.72),
          rgba(76,29,149,.45),
          rgba(30,58,138,.42)
        );

      --glass-bg:
        linear-gradient(
          135deg,
          rgba(31,41,55,.90),
          rgba(31,41,55,.76)
        );

      --glass-soft:
        linear-gradient(
          135deg,
          rgba(255,255,255,.12),
          rgba(168,85,247,.09),
          rgba(37,99,235,.09)
        );

      --text-main:#ffffff;
      --text-muted:#d1d5db;
      --text-soft:#e5e7eb;

      --card-bg:rgba(31,41,55,.88);
      --card-bg-solid:#1f2937;
      --card-border:rgba(216,180,254,.16);

      --purple:#a855f7;
      --purple-strong:#7c3aed;
      --purple-soft:#d8b4fe;
      --blue:#2563eb;

      --shadow:0 24px 70px rgba(0,0,0,.30);
      --shadow-soft:0 14px 40px rgba(0,0,0,.22);
    }

    body.light-mode{
      --page-bg:
        radial-gradient(circle at 16% 12%, rgba(168,85,247,.15), transparent 28%),
        radial-gradient(circle at 88% 70%, rgba(37,99,235,.14), transparent 34%),
        linear-gradient(135deg,#f8fafc 0%,#f3e8ff 46%,#dbeafe 100%);

      --header-bg:
        linear-gradient(
          135deg,
          rgba(255,255,255,.72),
          rgba(243,232,255,.56),
          rgba(219,234,254,.50)
        );

      --glass-bg:
        linear-gradient(
          135deg,
          rgba(255,255,255,.88),
          rgba(255,255,255,.72)
        );

      --glass-soft:
        linear-gradient(
          135deg,
          rgba(255,255,255,.82),
          rgba(243,232,255,.58),
          rgba(219,234,254,.54)
        );

      --text-main:#111827;
      --text-muted:#4b5563;
      --text-soft:#374151;

      --card-bg:rgba(255,255,255,.86);
      --card-bg-solid:#ffffff;
      --card-border:rgba(124,58,237,.16);

      --purple:#7c3aed;
      --purple-strong:#6d28d9;
      --purple-soft:#7c3aed;
      --blue:#2563eb;

      --shadow:0 24px 70px rgba(15,23,42,.14);
      --shadow-soft:0 14px 40px rgba(15,23,42,.10);
    }

    *{
      box-sizing:border-box;
    }

    html{
      scroll-behavior:smooth;
    }

    body{
      margin:0;
      font-family:Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:var(--page-bg);
      color:var(--text-main);
      transition:background .3s ease,color .3s ease;
    }

    a{
      color:inherit;
    }

    .site-header{
      position:sticky;
      top:0;
      z-index:1000;
      background:var(--header-bg);
      border-bottom:1px solid var(--card-border);
      backdrop-filter:blur(24px) saturate(190%);
      -webkit-backdrop-filter:blur(24px) saturate(190%);
      box-shadow:
        var(--shadow-soft),
        inset 0 1px 0 rgba(255,255,255,.10);
      transition:transform .28s ease, background .28s ease;
    }

    .nav-inner{
      max-width:1200px;
      min-height:74px;
      margin:0 auto;
      padding:0 22px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      position:relative;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:10px;
      text-decoration:none;
      color:var(--text-main);
      font-size:1.45rem;
      font-weight:950;
      letter-spacing:-.035em;
      position:relative;
      z-index:2;
    }

    .brand-icon{
      color:var(--purple-soft);
      font-size:1.35rem;
      line-height:1;
    }

    .brand-text-wrap{
      display:flex;
      flex-direction:column;
      line-height:1;
      position:relative;
    }

    .brand-status{
      position:absolute;
      top:28px;
      left:0;
      display:inline-flex;
      align-items:center;
      gap:5px;
      width:max-content;
      padding:5px 9px;
      border-radius:999px;
      color:#ffffff;
      background:linear-gradient(135deg,var(--purple-strong),var(--blue));
      border:1px solid rgba(255,255,255,.18);
      box-shadow:0 12px 28px rgba(0,0,0,.22);
      font-size:.68rem;
      font-weight:850;
      opacity:1;
      transform:translateY(0);
      transition:opacity .45s ease, transform .45s ease, visibility .45s ease;
      pointer-events:none;
      white-space:nowrap;
    }

    .brand-status.is-hidden{
      opacity:0;
      transform:translateY(-6px);
      visibility:hidden;
    }

    .status-dot{
      width:7px;
      height:7px;
      border-radius:999px;
      background:#22c55e;
      box-shadow:0 0 12px rgba(34,197,94,.9);
    }

    .desktop-nav{
      display:flex;
      align-items:center;
      gap:10px;
      padding:7px;
      border-radius:999px;
      background:rgba(255,255,255,.07);
      border:1px solid rgba(255,255,255,.10);
    }

    body.light-mode .desktop-nav{
      background:rgba(255,255,255,.52);
      border-color:rgba(124,58,237,.12);
    }

    .desktop-nav a{
      text-decoration:none;
      color:var(--text-main);
      font-size:.93rem;
      font-weight:800;
      opacity:.92;
      padding:10px 15px;
      border-radius:999px;
      transition:.2s ease;
    }

    .desktop-nav a:hover{
      color:#ffffff;
      background:rgba(168,85,247,.32);
    }

    .nav-actions{
      display:flex;
      align-items:center;
      gap:10px;
      position:relative;
      z-index:2;
    }

    .theme-toggle{
      width:42px;
      height:42px;
      border:1px solid var(--card-border);
      border-radius:999px;
      background:var(--glass-soft);
      color:var(--text-main);
      display:flex;
      align-items:center;
      justify-content:center;
      cursor:pointer;
      font-size:1.1rem;
      backdrop-filter:blur(18px) saturate(180%);
      -webkit-backdrop-filter:blur(18px) saturate(180%);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.12);
    }

    .mobile-menu-btn{
      display:none;
    }

    .mobile-menu{
      display:none;
    }

    @media(max-width:768px){
      .site-header{
        padding:8px 9px 5px;
        border-bottom:0;
        background:transparent;
        box-shadow:none;
        will-change:transform;
      }

      .site-header.mobile-hidden{
        transform:translateY(-120%);
      }

      .nav-inner{
        min-height:52px;
        padding:0 13px;
        border-radius:26px;
        border:1px solid var(--card-border);
        background:var(--glass-soft);
        backdrop-filter:blur(28px) saturate(220%);
        -webkit-backdrop-filter:blur(28px) saturate(220%);
        box-shadow:
          var(--shadow-soft),
          inset 0 1px 0 rgba(255,255,255,.20);
      }

      .brand{
        font-size:1rem;
        gap:7px;
      }

      .brand-icon{
        font-size:.9rem;
      }

      .brand-status{
        top:21px;
        padding:4px 7px;
        font-size:.54rem;
      }

      .desktop-nav{
        display:none;
      }

      .theme-toggle,
      .mobile-menu-btn{
        width:34px;
        height:34px;
      }

      .theme-toggle{
        font-size:.9rem;
      }

      .mobile-menu-btn{
        display:flex;
        align-items:center;
        justify-content:center;
        border:1px solid var(--card-border);
        border-radius:50%;
        background:var(--glass-soft);
        color:var(--text-main);
        font-size:1.35rem;
        line-height:1;
        cursor:pointer;
      }

      .mobile-menu-btn.is-open{
        background:rgba(168,85,247,.22);
      }

      .mobile-menu{
        position:absolute;
        top:70px;
        right:10px;
        width:min(68vw,300px);
        padding:24px 28px;
        border-radius:22px;
        border:1px solid var(--card-border);
        background:var(--glass-bg);
        backdrop-filter:blur(30px) saturate(210%);
        -webkit-backdrop-filter:blur(30px) saturate(210%);
        box-shadow:var(--shadow);
      }

      .mobile-menu.active{
        display:block;
      }

      .mobile-menu a{
        display:block;
        padding:0 0 24px;
        color:var(--text-main);
        text-decoration:none;
        font-size:1.04rem;
        font-weight:850;
      }

      .mobile-menu a:last-child{
        padding-bottom:0;
      }
    }
  </style>
</head>

<body>

  <header class="site-header" id="siteHeader">
    <div class="nav-inner">

      <a href="/" class="brand" aria-label="VPNHUB Home">
        <span class="brand-icon">◇</span>

        <span class="brand-text-wrap">
          <span class="brand-name">VPNHUB</span>

          <span class="brand-status" id="brandStatus">
            <span class="status-dot"></span>
            Secure learning hub
          </span>
        </span>
      </a>

      <nav class="desktop-nav" aria-label="Desktop navigation">
        <a href="/tutorials/">Tutorials</a>
        <a href="/videos/">Videos</a>
        <a href="/about/">About</a>
      </nav>

      <div class="nav-actions">
        <button
          class="theme-toggle"
          id="themeToggle"
          type="button"
          onclick="toggleTheme()"
          aria-label="Toggle light and dark mode"
        >
          <span id="themeIcon">🌙</span>
        </button>

        <button
          class="mobile-menu-btn"
          id="mobileMenuBtn"
          type="button"
          onclick="toggleMobileMenu()"
          aria-label="Open mobile menu"
          aria-expanded="false"
        >
          <span id="mobileMenuIcon">☰</span>
        </button>
      </div>

    </div>

    <nav class="mobile-menu" id="mobileMenu" aria-label="Mobile navigation">
      <a href="/tutorials/">Tutorials</a>
      <a href="/videos/">Videos</a>
      <a href="/about/">About</a>
    </nav>
  </header>

  {{ content | safe }}

  <script>
    function applyTheme(theme){
      const icon = document.getElementById("themeIcon");

      if(theme === "light"){
        document.body.classList.add("light-mode");
        if(icon) icon.textContent = "☀️";
      }else{
        document.body.classList.remove("light-mode");
        if(icon) icon.textContent = "🌙";
      }
    }

    function toggleTheme(){
      const currentTheme = localStorage.getItem("vpnhub-theme") || "dark";
      const nextTheme = currentTheme === "dark" ? "light" : "dark";

      localStorage.setItem("vpnhub-theme", nextTheme);
      applyTheme(nextTheme);
    }

    function toggleMobileMenu(){
      const menu = document.getElementById("mobileMenu");
      const icon = document.getElementById("mobileMenuIcon");
      const btn = document.getElementById("mobileMenuBtn");
      const header = document.getElementById("siteHeader");

      if(!menu || !icon || !btn) return;

      const isOpen = menu.classList.toggle("active");

      btn.classList.toggle("is-open", isOpen);
      btn.setAttribute("aria-expanded", isOpen ? "true" : "false");
      icon.textContent = isOpen ? "×" : "☰";

      if(header && isOpen){
        header.classList.remove("mobile-hidden");
      }
    }

    function closeMobileMenu(){
      const menu = document.getElementById("mobileMenu");
      const icon = document.getElementById("mobileMenuIcon");
      const btn = document.getElementById("mobileMenuBtn");

      if(!menu || !icon || !btn) return;

      menu.classList.remove("active");
      btn.classList.remove("is-open");
      btn.setAttribute("aria-expanded", "false");
      icon.textContent = "☰";
    }

    function showBrandStatusForFiveSeconds(){
      const status = document.getElementById("brandStatus");
      if(!status) return;

      status.classList.remove("is-hidden");

      setTimeout(function(){
        status.classList.add("is-hidden");
      }, 5000);
    }

    document.addEventListener("DOMContentLoaded", function(){
      const savedTheme = localStorage.getItem("vpnhub-theme") || "dark";
      applyTheme(savedTheme);
      showBrandStatusForFiveSeconds();
    });

    document.addEventListener("click", function(event){
      const menu = document.getElementById("mobileMenu");
      const btn = document.getElementById("mobileMenuBtn");

      if(!menu || !btn) return;

      if(!menu.contains(event.target) && !btn.contains(event.target)){
        closeMobileMenu();
      }
    });

    let lastScrollY = window.scrollY;
    let ticking = false;

    function handleMobileHeaderScroll(){
      const header = document.getElementById("siteHeader");
      const menu = document.getElementById("mobileMenu");

      if(!header) return;

      const isMobile = window.matchMedia("(max-width: 768px)").matches;

      if(!isMobile){
        header.classList.remove("mobile-hidden");
        return;
      }

      const currentScrollY = window.scrollY;
      const menuIsOpen = menu && menu.classList.contains("active");

      if(menuIsOpen){
        header.classList.remove("mobile-hidden");
        lastScrollY = currentScrollY;
        return;
      }

      if(currentScrollY < 20){
        header.classList.remove("mobile-hidden");
      }else if(currentScrollY > lastScrollY && currentScrollY > 80){
        header.classList.add("mobile-hidden");
      }else if(currentScrollY < lastScrollY){
        header.classList.remove("mobile-hidden");
      }

      lastScrollY = currentScrollY;
    }

    window.addEventListener("scroll", function(){
      if(!ticking){
        window.requestAnimationFrame(function(){
          handleMobileHeaderScroll();
          ticking = false;
        });

        ticking = true;
      }
    }, { passive:true });

    window.addEventListener("resize", function(){
      const header = document.getElementById("siteHeader");

      if(window.matchMedia("(min-width: 769px)").matches){
        if(header) header.classList.remove("mobile-hidden");
        closeMobileMenu();
      }
    });
  </script>

</body>
</html>
