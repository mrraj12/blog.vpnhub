<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{{ title or "VPNHUB" }}</title>

  {% if description %}
  <meta name="description" content="{{ description }}">
  {% endif %}

  <style>
    *{
      box-sizing:border-box;
    }

    html{
      scroll-behavior:smooth;
    }

    body{
      margin:0;
      font-family:Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:#111827;
      color:#ffffff;
    }

    a{
      color:inherit;
    }

    /* Desktop header */
    .site-header{
      position:sticky;
      top:0;
      z-index:1000;
      background:#111827;
      border-bottom:1px solid rgba(255,255,255,.08);
      transition:transform .28s ease;
    }

    .nav-inner{
      max-width:1200px;
      margin:0 auto;
      min-height:74px;
      padding:0 22px;
      display:flex;
      align-items:center;
      justify-content:space-between;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:10px;
      text-decoration:none;
      color:#ffffff;
      font-size:1.45rem;
      font-weight:950;
      letter-spacing:-.035em;
    }

    .brand-icon{
      color:#c084fc;
      font-size:1.35rem;
      line-height:1;
    }

    .desktop-nav{
      display:flex;
      align-items:center;
      gap:30px;
    }

    .desktop-nav a{
      text-decoration:none;
      color:#ffffff;
      font-size:.95rem;
      font-weight:800;
      opacity:.9;
      transition:.2s ease;
    }

    .desktop-nav a:hover{
      color:#c084fc;
      opacity:1;
    }

    .mobile-menu-btn{
      display:none;
    }

    .mobile-menu{
      display:none;
    }

    /* Mobile header */
    @media(max-width:768px){
      .site-header{
        position:sticky;
        top:0;
        z-index:1000;
        padding:10px 12px 6px;
        background:linear-gradient(
          180deg,
          #050509 0%,
          rgba(5,5,9,.96) 72%,
          rgba(76,29,149,.12) 100%
        );
        border-bottom:0;
        will-change:transform;
      }

      .site-header.mobile-hidden{
        transform:translateY(-110%);
      }

      .nav-inner{
        min-height:60px;
        padding:0 18px;
        border-radius:30px;
        border:1px solid rgba(216,180,254,.12);
        background:rgba(7,7,13,.88);
        box-shadow:
          0 10px 26px rgba(0,0,0,.28),
          inset 0 1px 0 rgba(255,255,255,.04);
        backdrop-filter:blur(14px);
      }

      .brand{
        font-size:1.22rem;
        gap:8px;
      }

      .brand-icon{
        font-size:1.05rem;
      }

      .desktop-nav{
        display:none;
      }

      .mobile-menu-btn{
        display:flex;
        align-items:center;
        justify-content:center;
        width:40px;
        height:40px;
        border:0;
        border-radius:50%;
        background:transparent;
        color:#ffffff;
        font-size:1.65rem;
        line-height:1;
        cursor:pointer;
      }

      .mobile-menu-btn.is-open{
        background:rgba(255,255,255,.1);
      }

      .mobile-menu{
        position:absolute;
        top:82px;
        right:16px;
        width:min(66vw,300px);
        padding:28px 34px;
        border-radius:22px;
        border:1px solid rgba(216,180,254,.14);
        background:linear-gradient(135deg,#171b35,#1f2748);
        box-shadow:0 24px 60px rgba(0,0,0,.45);
      }

      .mobile-menu.active{
        display:block;
      }

      .mobile-menu a{
        display:block;
        padding:0 0 28px;
        color:#ffffff;
        text-decoration:none;
        font-size:1.18rem;
        font-weight:800;
        line-height:1.2;
      }

      .mobile-menu a:last-child{
        padding-bottom:0;
      }
    }

    @media(max-width:420px){
      .site-header{
        padding:9px 10px 5px;
      }

      .nav-inner{
        min-height:56px;
        padding:0 16px;
        border-radius:28px;
      }

      .brand{
        font-size:1.12rem;
      }

      .brand-icon{
        font-size:1rem;
      }

      .mobile-menu-btn{
        width:38px;
        height:38px;
        font-size:1.55rem;
      }

      .mobile-menu{
        top:76px;
        right:14px;
        width:68vw;
        padding:26px 32px;
      }

      .mobile-menu a{
        font-size:1.12rem;
        padding-bottom:26px;
      }
    }
  </style>
</head>

<body>

  <header class="site-header" id="siteHeader">
    <div class="nav-inner">

      <a href="/" class="brand" aria-label="VPNHUB Home">
        <span class="brand-icon">◇</span>
        <span>VPNHUB</span>
      </a>

      <nav class="desktop-nav" aria-label="Desktop navigation">
        <a href="/tutorials/">Tutorials</a>
        <a href="/videos/">Videos</a>
        <a href="/about/">About</a>
      </nav>

      <button
        class="mobile-menu-btn"
        id="mobileMenuBtn"
        type="button"
        onclick="toggleMobileMenu()"
        aria-label="Open mobile menu"
        aria-expanded="false"
      >
        <span id="mobileMenuIcon">☰</span>
      </button>

    </div>

    <nav class="mobile-menu" id="mobileMenu" aria-label="Mobile navigation">
      <a href="/tutorials/">Tutorials</a>
      <a href="/videos/">Videos</a>
      <a href="/about/">About</a>
    </nav>
  </header>

  {{ content | safe }}

  <script>
    function toggleMobileMenu(){
      const menu = document.getElementById("mobileMenu");
      const icon = document.getElementById("mobileMenuIcon");
      const btn = document.getElementById("mobileMenuBtn");
      const header = document.getElementById("siteHeader");

      if(!menu || !icon || !btn) return;

      const isOpen = menu.classList.toggle("active");

      btn.classList.toggle("is-open", isOpen);
      btn.setAttribute("aria-expanded", isOpen ? "true" : "false");
      icon.textContent = isOpen ? "×" : "☰";

      if(header && isOpen){
        header.classList.remove("mobile-hidden");
      }
    }

    function closeMobileMenu(){
      const menu = document.getElementById("mobileMenu");
      const icon = document.getElementById("mobileMenuIcon");
      const btn = document.getElementById("mobileMenuBtn");

      if(!menu || !icon || !btn) return;

      menu.classList.remove("active");
      btn.classList.remove("is-open");
      btn.setAttribute("aria-expanded", "false");
      icon.textContent = "☰";
    }

    document.addEventListener("click", function(event){
      const menu = document.getElementById("mobileMenu");
      const btn = document.getElementById("mobileMenuBtn");

      if(!menu || !btn) return;

      const clickedInsideMenu = menu.contains(event.target);
      const clickedButton = btn.contains(event.target);

      if(!clickedInsideMenu && !clickedButton){
        closeMobileMenu();
      }
    });

    let lastScrollY = window.scrollY;
    let ticking = false;

    function handleMobileHeaderScroll(){
      const header = document.getElementById("siteHeader");
      const menu = document.getElementById("mobileMenu");

      if(!header) return;

      const isMobile = window.matchMedia("(max-width: 768px)").matches;

      if(!isMobile){
        header.classList.remove("mobile-hidden");
        return;
      }

      const currentScrollY = window.scrollY;
      const menuIsOpen = menu && menu.classList.contains("active");

      if(menuIsOpen){
        header.classList.remove("mobile-hidden");
        lastScrollY = currentScrollY;
        return;
      }

      if(currentScrollY < 20){
        header.classList.remove("mobile-hidden");
      }else if(currentScrollY > lastScrollY && currentScrollY > 80){
        header.classList.add("mobile-hidden");
      }else if(currentScrollY < lastScrollY){
        header.classList.remove("mobile-hidden");
      }

      lastScrollY = currentScrollY;
    }

    window.addEventListener("scroll", function(){
      if(!ticking){
        window.requestAnimationFrame(function(){
          handleMobileHeaderScroll();
          ticking = false;
        });

        ticking = true;
      }
    }, { passive:true });

    window.addEventListener("resize", function(){
      const header = document.getElementById("siteHeader");

      if(window.matchMedia("(min-width: 769px)").matches){
        if(header) header.classList.remove("mobile-hidden");
        closeMobileMenu();
      }
    });
  </script>

</body>
</html>
