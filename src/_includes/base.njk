<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{{ title or "VPNHUB" }}</title>

  {% if description %}
  <meta name="description" content="{{ description }}">
  {% endif %}

  <style>
    :root{
      --site-bg:#111827;
      --site-bg-2:#4c1d95;
      --site-bg-3:#1e3a8a;

      --text-main:#ffffff;
      --text-muted:#d1d5db;

      --card-bg:rgba(31,41,55,.82);
      --card-border:rgba(216,180,254,.18);

      --purple:#a855f7;
      --purple-soft:#d8b4fe;
      --blue:#2563eb;

      --shadow:0 18px 44px rgba(0,0,0,.34);
    }

    body.light-mode{
      --site-bg:#f8fafc;
      --site-bg-2:#f3e8ff;
      --site-bg-3:#dbeafe;

      --text-main:#111827;
      --text-muted:#4b5563;

      --card-bg:rgba(255,255,255,.82);
      --card-border:rgba(124,58,237,.18);

      --purple:#7c3aed;
      --purple-soft:#7c3aed;
      --blue:#2563eb;

      --shadow:0 18px 44px rgba(15,23,42,.14);
    }

    *{
      box-sizing:border-box;
    }

    html{
      scroll-behavior:smooth;
    }

    body{
      margin:0;
      font-family:Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at 16% 12%, rgba(168,85,247,.26), transparent 28%),
        radial-gradient(circle at 88% 70%, rgba(37,99,235,.24), transparent 34%),
        linear-gradient(135deg,var(--site-bg) 0%,var(--site-bg-2) 46%,var(--site-bg-3) 100%);
      color:var(--text-main);
      transition:background .3s ease,color .3s ease;
    }

    a{
      color:inherit;
    }

    /* Floating overlay header */
    .site-header{
      position:fixed;
      top:18px;
      left:0;
      right:0;
      z-index:1000;
      padding:0 20px;
      background:transparent;
      pointer-events:none;
      transition:transform .28s ease;
    }

    .nav-inner{
      width:min(1240px,100%);
      margin:0 auto;
      min-height:58px;
      padding:0 14px 0 22px;
      display:grid;
      grid-template-columns:1fr auto 1fr;
      align-items:center;
      position:relative;
      pointer-events:auto;
      border-radius:999px;
      border:1px solid rgba(216,180,254,.16);
      background:
        linear-gradient(
          135deg,
          rgba(13,18,36,.84),
          rgba(48,24,108,.76),
          rgba(91,45,215,.70)
        );
      backdrop-filter:blur(26px) saturate(190%);
      -webkit-backdrop-filter:blur(26px) saturate(190%);
      box-shadow:
        0 18px 54px rgba(0,0,0,.30),
        inset 0 1px 0 rgba(255,255,255,.13),
        inset 0 -1px 0 rgba(255,255,255,.05);
      overflow:hidden;
    }

    body.light-mode .nav-inner{
      background:
        linear-gradient(
          135deg,
          rgba(255,255,255,.86),
          rgba(243,232,255,.68),
          rgba(219,234,254,.54)
        );
      box-shadow:
        0 18px 44px rgba(15,23,42,.14),
        inset 0 1px 0 rgba(255,255,255,.72),
        inset 0 -1px 0 rgba(255,255,255,.28);
    }

    .nav-inner::before{
      content:"";
      position:absolute;
      inset:0;
      border-radius:inherit;
      pointer-events:none;
      background:
        radial-gradient(circle at 12% 0%, rgba(255,255,255,.18), transparent 30%),
        radial-gradient(circle at 88% 100%, rgba(96,165,250,.16), transparent 34%);
      opacity:.9;
    }

    .brand{
      position:relative;
      z-index:1;
      justify-self:start;
      display:flex;
      align-items:center;
      gap:9px;
      text-decoration:none;
      color:var(--text-main);
      font-size:1.22rem;
      font-weight:950;
      letter-spacing:-.035em;
      text-shadow:0 1px 14px rgba(255,255,255,.10);
    }

    .brand-logo{
      width:24px;
      height:24px;
      color:var(--purple-soft);
      display:block;
      flex:0 0 auto;
      filter:drop-shadow(0 0 9px rgba(192,132,252,.42));
    }

    .brand-name{
      line-height:1;
    }

    .desktop-nav{
      position:relative;
      z-index:1;
      justify-self:center;
      display:flex;
      align-items:center;
      gap:8px;
      padding:6px;
      border-radius:999px;
      background:rgba(255,255,255,.08);
      border:1px solid rgba(255,255,255,.10);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.10),
        0 10px 26px rgba(0,0,0,.10);
    }

    body.light-mode .desktop-nav{
      background:rgba(255,255,255,.55);
      border-color:rgba(124,58,237,.12);
    }

    .desktop-nav a{
      text-decoration:none;
      color:var(--text-main);
      font-size:.9rem;
      font-weight:850;
      opacity:.94;
      padding:8px 15px;
      border-radius:999px;
      transition:.2s ease;
    }

    .desktop-nav a:hover{
      color:#ffffff;
      background:rgba(168,85,247,.32);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.14),
        0 8px 20px rgba(124,58,237,.22);
      opacity:1;
    }

    .nav-actions{
      position:relative;
      z-index:1;
      justify-self:end;
      display:flex;
      align-items:center;
      gap:8px;
    }

    .theme-toggle{
      width:40px;
      height:40px;
      border:1px solid rgba(255,255,255,.15);
      border-radius:999px;
      background:rgba(255,255,255,.10);
      color:var(--text-main);
      display:flex;
      align-items:center;
      justify-content:center;
      cursor:pointer;
      font-size:1.05rem;
      backdrop-filter:blur(16px) saturate(180%);
      -webkit-backdrop-filter:blur(16px) saturate(180%);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.14),
        0 8px 20px rgba(0,0,0,.16);
      transition:.2s ease;
    }

    .theme-toggle:hover{
      background:rgba(168,85,247,.24);
      transform:translateY(-1px);
    }

    .mobile-menu-btn{
      display:none;
    }

    .mobile-menu{
      display:none;
    }

    /* Push page hero content down without creating body background strip */
    .hero,
    .tutorials-hero,
    .videos-hero,
    .about-hero{
      padding-top:130px !important;
    }

    @media(max-width:768px){
      .site-header{
        top:12px;
        padding:0 20px;
      }

      .site-header.mobile-hidden{
        transform:translateY(-125%);
      }

      .nav-inner{
        width:100%;
        min-height:58px;
        padding:0 14px 0 18px;
        display:flex;
        justify-content:space-between;
        border-radius:999px;
        background:
          linear-gradient(
            135deg,
            rgba(10,12,28,.88),
            rgba(37,24,86,.78),
            rgba(73,42,190,.72)
          );
      }

      body.light-mode .nav-inner{
        background:
          linear-gradient(
            135deg,
            rgba(255,255,255,.88),
            rgba(243,232,255,.66),
            rgba(219,234,254,.52)
          );
      }

      .brand{
        font-size:1.06rem;
        gap:8px;
      }

      .brand-logo{
        width:22px;
        height:22px;
      }

      .desktop-nav{
        display:none;
      }

      .nav-actions{
        gap:8px;
      }

      .theme-toggle{
        width:38px;
        height:38px;
        font-size:1rem;
      }

      .mobile-menu-btn{
        display:flex;
        align-items:center;
        justify-content:center;
        width:38px;
        height:38px;
        border:1px solid rgba(255,255,255,.15);
        border-radius:50%;
        background:rgba(255,255,255,.10);
        color:var(--text-main);
        font-size:1.42rem;
        line-height:1;
        cursor:pointer;
        backdrop-filter:blur(18px) saturate(180%);
        -webkit-backdrop-filter:blur(18px) saturate(180%);
        box-shadow:
          inset 0 1px 0 rgba(255,255,255,.14),
          0 8px 20px rgba(0,0,0,.18);
      }

      .mobile-menu-btn.is-open{
        background:rgba(168,85,247,.22);
        border-color:rgba(216,180,254,.24);
      }

      .mobile-menu{
        position:absolute;
        top:74px;
        right:20px;
        width:min(72vw,310px);
        padding:24px 28px;
        border-radius:24px;
        border:1px solid rgba(216,180,254,.16);
        background:
          linear-gradient(
            135deg,
            rgba(31,41,55,.82),
            rgba(76,29,149,.48),
            rgba(30,58,138,.36)
          );
        backdrop-filter:blur(30px) saturate(210%);
        -webkit-backdrop-filter:blur(30px) saturate(210%);
        box-shadow:
          0 26px 70px rgba(0,0,0,.48),
          inset 0 1px 0 rgba(255,255,255,.18),
          inset 0 -1px 0 rgba(255,255,255,.06);
        pointer-events:auto;
      }

      body.light-mode .mobile-menu{
        background:
          linear-gradient(
            135deg,
            rgba(255,255,255,.84),
            rgba(243,232,255,.68),
            rgba(219,234,254,.58)
          );
        box-shadow:
          0 26px 70px rgba(15,23,42,.18),
          inset 0 1px 0 rgba(255,255,255,.75);
      }

      .mobile-menu.active{
        display:block;
      }

      .mobile-menu a{
        display:block;
        padding:0 0 24px;
        color:var(--text-main);
        text-decoration:none;
        font-size:1.04rem;
        font-weight:850;
        line-height:1.2;
        text-shadow:0 1px 14px rgba(0,0,0,.18);
      }

      .mobile-menu a:last-child{
        padding-bottom:0;
      }

      .hero,
      .tutorials-hero,
      .videos-hero,
      .about-hero{
        padding-top:112px !important;
      }
    }

    @media(max-width:420px){
      .site-header{
        top:11px;
        padding:0 16px;
      }

      .nav-inner{
        min-height:56px;
        padding:0 12px 0 16px;
      }

      .brand{
        font-size:1rem;
      }

      .brand-logo{
        width:20px;
        height:20px;
      }

      .theme-toggle,
      .mobile-menu-btn{
        width:36px;
        height:36px;
      }

      .mobile-menu-btn{
        font-size:1.35rem;
      }

      .mobile-menu{
        top:72px;
        right:16px;
        width:74vw;
        padding:24px 26px;
      }

      .hero,
      .tutorials-hero,
      .videos-hero,
      .about-hero{
        padding-top:106px !important;
      }
    }
  </style>
</head>

<body>

  <header class="site-header" id="siteHeader">
    <div class="nav-inner">

      <a href="/" class="brand" aria-label="VPNHUB Home">
        <svg
          class="brand-logo"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>
        </svg>

        <span class="brand-name">VPNHUB</span>
      </a>

      <nav class="desktop-nav" aria-label="Desktop navigation">
        <a href="/tutorials/">Tutorials</a>
        <a href="/videos/">Videos</a>
        <a href="/about/">About</a>
      </nav>

      <div class="nav-actions">
        <button
          class="theme-toggle"
          id="themeToggle"
          type="button"
          onclick="toggleTheme()"
          aria-label="Toggle light and dark mode"
        >
          <span id="themeIcon">🌙</span>
        </button>

        <button
          class="mobile-menu-btn"
          id="mobileMenuBtn"
          type="button"
          onclick="toggleMobileMenu()"
          aria-label="Open mobile menu"
          aria-expanded="false"
        >
          <span id="mobileMenuIcon">☰</span>
        </button>
      </div>

    </div>

    <nav class="mobile-menu" id="mobileMenu" aria-label="Mobile navigation">
      <a href="/tutorials/">Tutorials</a>
      <a href="/videos/">Videos</a>
      <a href="/about/">About</a>
    </nav>
  </header>

  {{ content | safe }}

  <script>
    function applyTheme(theme){
      const icon = document.getElementById("themeIcon");

      if(theme === "light"){
        document.body.classList.add("light-mode");
        if(icon) icon.textContent = "☀️";
      }else{
        document.body.classList.remove("light-mode");
        if(icon) icon.textContent = "🌙";
      }
    }

    function toggleTheme(){
      const currentTheme = localStorage.getItem("vpnhub-theme") || "dark";
      const nextTheme = currentTheme === "dark" ? "light" : "dark";

      localStorage.setItem("vpnhub-theme", nextTheme);
      applyTheme(nextTheme);
    }

    function toggleMobileMenu(){
      const menu = document.getElementById("mobileMenu");
      const icon = document.getElementById("mobileMenuIcon");
      const btn = document.getElementById("mobileMenuBtn");
      const header = document.getElementById("siteHeader");

      if(!menu || !icon || !btn) return;

      const isOpen = menu.classList.toggle("active");

      btn.classList.toggle("is-open", isOpen);
      btn.setAttribute("aria-expanded", isOpen ? "true" : "false");
      icon.textContent = isOpen ? "×" : "☰";

      if(header && isOpen){
        header.classList.remove("mobile-hidden");
      }
    }

    function closeMobileMenu(){
      const menu = document.getElementById("mobileMenu");
      const icon = document.getElementById("mobileMenuIcon");
      const btn = document.getElementById("mobileMenuBtn");

      if(!menu || !icon || !btn) return;

      menu.classList.remove("active");
      btn.classList.remove("is-open");
      btn.setAttribute("aria-expanded", "false");
      icon.textContent = "☰";
    }

    document.addEventListener("DOMContentLoaded", function(){
      const savedTheme = localStorage.getItem("vpnhub-theme") || "dark";
      applyTheme(savedTheme);
    });

    document.addEventListener("click", function(event){
      const menu = document.getElementById("mobileMenu");
      const btn = document.getElementById("mobileMenuBtn");

      if(!menu || !btn) return;

      const clickedInsideMenu = menu.contains(event.target);
      const clickedButton = btn.contains(event.target);

      if(!clickedInsideMenu && !clickedButton){
        closeMobileMenu();
      }
    });

    let lastScrollY = window.scrollY;
    let ticking = false;

    function handleMobileHeaderScroll(){
      const header = document.getElementById("siteHeader");
      const menu = document.getElementById("mobileMenu");

      if(!header) return;

      const isMobile = window.matchMedia("(max-width: 768px)").matches;

      if(!isMobile){
        header.classList.remove("mobile-hidden");
        return;
      }

      const currentScrollY = window.scrollY;
      const menuIsOpen = menu && menu.classList.contains("active");

      if(menuIsOpen){
        header.classList.remove("mobile-hidden");
        lastScrollY = currentScrollY;
        return;
      }

      if(currentScrollY < 20){
        header.classList.remove("mobile-hidden");
      }else if(currentScrollY > lastScrollY && currentScrollY > 80){
        header.classList.add("mobile-hidden");
      }else if(currentScrollY < lastScrollY){
        header.classList.remove("mobile-hidden");
      }

      lastScrollY = currentScrollY;
    }

    window.addEventListener("scroll", function(){
      if(!ticking){
        window.requestAnimationFrame(function(){
          handleMobileHeaderScroll();
          ticking = false;
        });

        ticking = true;
      }
    }, { passive:true });

    window.addEventListener("resize", function(){
      const header = document.getElementById("siteHeader");

      if(window.matchMedia("(min-width: 769px)").matches){
        if(header) header.classList.remove("mobile-hidden");
        closeMobileMenu();
      }
    });
  </script>

</body>
</html>
