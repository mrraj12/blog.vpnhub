  padding:3px 7px;
  border-radius:7px;
  background:rgba(15,23,42,.75);
  color:#d8b4fe;
}

@media(max-width:1000px){
  .video-grid{
    grid-template-columns:repeat(2,1fr);
  }

  .videos-hero h1{
    font-size:3.1rem;
  }
}

@media(max-width:768px){
  .videos-hero{
    padding:56px 16px 42px;
  }

  .videos-badge{
    margin-bottom:24px;
    padding:9px 16px;
    font-size:.78rem;
  }

  .videos-hero h1{
    font-size:2.2rem;
    line-height:1.14;
  }

