---
layout: base.njk
title: VPNHUB Videos
description: VPN video tutorials, setup walkthroughs, privacy lessons, and server guides.
permalink: /videos/
---

<main class="videos-page">

  <section class="videos-hero">
    <div class="videos-hero-inner">

      <span class="videos-badge">
        VPN Videos • Setup Walkthroughs • Security Lessons
      </span>

      <h1>
        VPN Video Guides,
        <span>Step by Step</span>
      </h1>

      <p>
        Watch VPNHUB video tutorials for VPN setup, Hiddify setup, Android VPN,
        Windows VPN, secure browsing, privacy protection, and server management.
      </p>

    </div>
  </section>

  <section class="videos-section">
    <div class="videos-inner">

      <div class="section-heading">
        <h2>Latest Videos</h2>
        <p>Watch practical VPN tutorials and setup walkthroughs.</p>
      </div>

      {% if collections.allVideos.length %}
      <div class="video-grid">

        {% for video in collections.allVideos %}
        <article class="video-card">

          <div class="video-frame">

            {% if video.data.youtubeId %}
            <iframe
              src="https://www.youtube.com/embed/{{ video.data.youtubeId }}"
              title="{{ video.data.title }}"
              loading="lazy"
              allowfullscreen>
            </iframe>
            {% elif video.data.thumbnail %}
            <img src="{{ video.data.thumbnail }}" alt="{{ video.data.title }}">
            {% else %}
            <div class="video-placeholder">
              <span>▶</span>
              <p>Video Coming Soon</p>
            </div>
            {% endif %}

          </div>

          <div class="video-body">

            <div class="video-meta-row">
              <span class="video-category">
                {{ video.data.category or "VPN Video" }}
              </span>

              {% if video.data.date %}
              <span class="video-date">
                {{ video.data.date | readableDate }}
              </span>
              {% endif %}
            </div>

            <h3>{{ video.data.title }}</h3>

            {% if video.data.description %}
            <p>{{ video.data.description }}</p>
            {% endif %}

            {% if video.data.youtubeId %}
            <a
              class="watch-link"
              href="https://www.youtube.com/watch?v={{ video.data.youtubeId }}"
              target="_blank"
              rel="noopener">
              Watch on YouTube →
            </a>
            {% endif %}

          </div>

        </article>
        {% endfor %}

      </div>
      {% else %}

      <div class="empty-state">
        <h3>No videos found</h3>
        <p>
          Add video files inside <code>src/videos/</code> or create videos from the admin panel.
        </p>
      </div>

      {% endif %}

    </div>
  </section>

</main>

<style>
.videos-page{
  min-height:100vh;
  color:var(--text-main);
  background:
    radial-gradient(circle at 16% 12%, rgba(168,85,247,.26), transparent 28%),
    radial-gradient(circle at 88% 70%, rgba(37,99,235,.24), transparent 34%),
    linear-gradient(135deg,var(--site-bg) 0%,var(--site-bg-2) 46%,var(--site-bg-3) 100%);
}

.videos-hero{
  padding:88px 20px 66px;
  text-align:center;
}

.videos-hero-inner{
  max-width:920px;
  margin:0 auto;
}

.videos-badge{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:10px 24px;
  margin-bottom:30px;
  border-radius:999px;
  border:1px solid var(--card-border);
  background:rgba(168,85,247,.16);
  color:var(--purple-soft);
  font-size:.95rem;
}

.videos-hero h1{
  margin:0 0 22px;
  color:var(--text-main);
  font-size:3.7rem;
  line-height:1.08;
  font-weight:950;
  letter-spacing:-.05em;
}

.videos-hero h1 span{
  color:var(--purple);
}

.videos-hero p{
  max-width:760px;
  margin:0 auto;
  color:var(--text-muted);
  font-size:1.15rem;
  line-height:1.75;
}

.videos-section{
  padding:52px 20px 110px;
}

.videos-inner{
  max-width:1160px;
  margin:0 auto;
}

.section-heading{
  margin-bottom:38px;
  text-align:center;
}

.section-heading h2{
  margin:0 0 12px;
  color:var(--text-main);
  font-size:2.1rem;
  line-height:1.15;
  font-weight:950;
  letter-spacing:-.035em;
}

.section-heading p{
  margin:0;
  color:var(--text-muted);
  font-size:1.02rem;
}

.video-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:28px;
}

.video-card{
  overflow:hidden;
  border-radius:18px;
  background:var(--card-bg);
  border:1px solid var(--card-border);
  box-shadow:var(--shadow);
  backdrop-filter:blur(22px) saturate(180%);
  -webkit-backdrop-filter:blur(22px) saturate(180%);
  transition:.25s ease;
}

.video-card:hover{
  transform:translateY(-7px);
}

.video-frame{
  width:100%;
  aspect-ratio:16/9;
  overflow:hidden;
  background:
    linear-gradient(135deg,rgba(124,58,237,.42),rgba(37,99,235,.32)),
    rgba(15,23,42,.9);
}

.video-frame iframe,
.video-frame img{
  width:100%;
  height:100%;
  display:block;
  border:0;
  object-fit:cover;
}

.video-placeholder{
  width:100%;
  height:100%;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  color:#ffffff;
}

.video-placeholder span{
  width:64px;
  height:64px;
  border-radius:999px;
  display:flex;
  align-items:center;
  justify-content:center;
  margin-bottom:14px;
  background:rgba(255,255,255,.16);
  border:1px solid rgba(255,255,255,.2);
  font-size:1.7rem;
}

.video-placeholder p{
  margin:0;
  color:#e5e7eb;
  font-weight:800;
}

.video-body{
  padding:24px;
}

.video-meta-row{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:14px;
  margin-bottom:18px;
}

.video-category{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:6px 12px;
  border-radius:999px;
  background:rgba(124,58,237,.42);
  color:#d8b4fe;
  font-size:.74rem;
  font-weight:900;
}

body.light-mode .video-category{
  color:#7c3aed;
  background:rgba(124,58,237,.12);
}

.video-date{
  color:var(--text-muted);
  font-size:.78rem;
  white-space:nowrap;
}

.video-body h3{
  margin:0 0 14px;
  color:var(--text-main);
  font-size:1.25rem;
  line-height:1.35;
  font-weight:950;
}

.video-body p{
  margin:0 0 20px;
  color:var(--text-muted);
  font-size:.94rem;
  line-height:1.65;
}

.watch-link{
  color:var(--purple-soft);
  text-decoration:none;
  font-size:.92rem;
  font-weight:900;
}

.empty-state{
  max-width:620px;
  margin:0 auto;
  padding:34px;
  border-radius:20px;
  text-align:center;
  background:var(--card-bg);
  border:1px solid var(--card-border);
  box-shadow:var(--shadow);
}

.empty-state h3{
  margin:0 0 12px;
  color:var(--text-main);
  font-size:1.45rem;
}

.empty-state p{
  margin:0;
  color:var(--text-muted);
  line-height:1.7;
}

