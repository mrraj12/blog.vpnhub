---
layout: base.njk
title: About VPNHUB
description: Learn about VPNHUB, a practical VPN tutorial and privacy guide platform.
permalink: /about/
---

<main class="about-page">

  <section class="about-hero">
    <div class="about-hero-inner">

      <span class="about-badge">
        {{ siteContent.aboutPage.badge }}
      </span>

      <h1>
        {{ siteContent.aboutPage.titleBefore }}
        <span>{{ siteContent.aboutPage.titleHighlight }}</span>
      </h1>

      <p>
        {{ siteContent.aboutPage.description }}
      </p>

    </div>
  </section>

  <section class="about-section">
    <div class="about-inner">

      <article class="about-card main-card">
        <h2>{{ siteContent.aboutPage.mainTitle }}</h2>

        <p>
          {{ siteContent.aboutPage.mainParagraphOne }}
        </p>

        <p>
          {{ siteContent.aboutPage.mainParagraphTwo }}
        </p>
      </article>

      <div class="about-grid">

        {% for card in siteContent.aboutPage.cards %}
        <article class="about-card">
          <div class="about-icon">{{ card.icon }}</div>
          <h3>{{ card.title }}</h3>
          <p>
            {{ card.text }}
          </p>
        </article>
        {% endfor %}

      </div>

      <article class="about-card mission-card">
        <h2>{{ siteContent.aboutPage.missionTitle }}</h2>

        <p>
          {{ siteContent.aboutPage.missionText }}
        </p>
      </article>

    </div>
  </section>

</main>

<style>
.about-page{
  min-height:100vh;
  color:var(--text-main);
  background:
    radial-gradient(circle at 16% 12%, rgba(168,85,247,.26), transparent 28%),
    radial-gradient(circle at 88% 70%, rgba(37,99,235,.24), transparent 34%),
    linear-gradient(135deg,var(--site-bg) 0%,var(--site-bg-2) 46%,var(--site-bg-3) 100%);
}

.about-hero{
  padding:96px 20px 72px;
  text-align:center;
}

.about-hero-inner{
  max-width:920px;
  margin:0 auto;
}

.about-badge{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:10px 24px;
  margin-bottom:34px;
  border-radius:999px;
  border:1px solid var(--card-border);
  background:rgba(168,85,247,.16);
  color:var(--purple-soft);
  font-size:.95rem;
}

.about-hero h1{
  margin:0 0 24px;
  color:var(--text-main);
  font-size:4rem;
  line-height:1.08;
  font-weight:950;
  letter-spacing:-.05em;
}

.about-hero h1 span{
  color:var(--purple);
}

.about-hero p{
  max-width:760px;
  margin:0 auto;
  color:var(--text-muted);
  font-size:1.22rem;
  line-height:1.75;
}

.about-section{
  padding:56px 20px 110px;
}

.about-inner{
  max-width:1100px;
  margin:0 auto;
}

.about-card{
  border-radius:22px;
  background:var(--card-bg);
  border:1px solid var(--card-border);
  box-shadow:var(--shadow);
  backdrop-filter:blur(22px) saturate(180%);
  -webkit-backdrop-filter:blur(22px) saturate(180%);
}

.main-card,
.mission-card{
  padding:36px;
}

.main-card{
  margin-bottom:28px;
}

.mission-card{
  margin-top:28px;
}

.about-card h2{
  margin:0 0 18px;
  color:var(--text-main);
  font-size:2rem;
  line-height:1.2;
  font-weight:950;
  letter-spacing:-.035em;
}

.about-card h3{
  margin:0 0 12px;
  color:var(--text-main);
  font-size:1.25rem;
  line-height:1.3;
  font-weight:950;
}

.about-card p{
  margin:0 0 16px;
  color:var(--text-muted);
  font-size:1.02rem;
  line-height:1.75;
}

.about-card p:last-child{
  margin-bottom:0;
}

.about-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:24px;
}

.about-grid .about-card{
  padding:26px;
  transition:.25s ease;
}

.about-grid .about-card:hover{
  transform:translateY(-7px);
}

.about-icon{
  margin-bottom:18px;
  font-size:2.1rem;
}

@media(max-width:1000px){
  .about-grid{
    grid-template-columns:repeat(2,1fr);
  }

  .about-hero h1{
    font-size:3.3rem;
  }
}

@media(max-width:768px){
  .about-hero{
    padding:58px 16px 46px;
  }

  .about-badge{
    margin-bottom:24px;
    padding:9px 16px;
    font-size:.78rem;
  }

  .about-hero h1{
    font-size:2.35rem;
    line-height:1.14;
  }

  .about-hero p{
    font-size:1rem;
    line-height:1.7;
  }

  .about-section{
    padding:42px 16px 76px;
  }

  .main-card,
  .mission-card{
    padding:26px 22px;
    border-radius:18px;
  }

  .about-card h2{
    font-size:1.65rem;
  }

  .about-grid{
    grid-template-columns:1fr;
    gap:22px;
  }

  .about-grid .about-card{
    padding:24px 22px;
    border-radius:18px;
  }
}

@media(max-width:420px){
  .about-hero h1{
    font-size:2.05rem;
  }
}
</style>
