---
layout: base.njk
title: VPNHUB - VPN Tutorials & Guides
description: VPN tutorials, privacy guides, setup tips, and secure browsing lessons.
---

<main class="vpnhub-page">

  <section class="hero">
    <div class="hero-inner">

      <span class="hero-badge">
        {{ siteContent.homePage.badge }}
      </span>

      <h1>
        {{ siteContent.homePage.titleBefore }}
        <span>{{ siteContent.homePage.titleHighlight }}</span>
      </h1>

      <p>
        {{ siteContent.homePage.description }}
      </p>

      {% if siteContent.homePage.actions.length %}
      <div class="hero-actions">
        {% for action in siteContent.homePage.actions %}
        <a
          class="hero-action-btn {{ action.style or 'primary' }}"
          href="{{ action.url }}"
          {% if action.newTab %}target="_blank" rel="noopener"{% endif %}
        >
          {{ action.label }}
        </a>
        {% endfor %}
      </div>
      {% endif %}

    </div>
  </section>

  <section class="section features-section">
    <div class="section-inner">

      <h2>Why Learn With VPNHUB?</h2>

      <div class="feature-grid">

        <article class="feature-card">
          <div class="feature-icon">◇</div>
          <h3>Beginner Friendly</h3>
          <p>Simple VPN setup tutorials for Android, iOS, Windows, Mac, and more.</p>
        </article>

        <article class="feature-card">
          <div class="feature-icon">ϟ</div>
          <h3>Fast Setup Guides</h3>
          <p>Follow practical steps to connect quickly and avoid common VPN problems.</p>
        </article>

        <article class="feature-card">
          <div class="feature-icon">◎</div>
          <h3>Server Tips</h3>
          <p>Learn how to choose better VPN servers for speed, privacy, and streaming.</p>
        </article>

        <article class="feature-card">
          <div class="feature-icon">▢</div>
          <h3>Privacy Basics</h3>
          <p>Understand VPN privacy, IP protection, DNS leaks, and safer browsing habits.</p>
        </article>

      </div>

    </div>
  </section>

  <section class="section latest-section">
    <div class="section-inner">

      <h2>Pinned Tutorials</h2>

      {% if collections.homepageTutorials.length %}
      <div class="post-grid">

        {% for post in collections.homepageTutorials %}
        <article class="post-card">

          {% if post.data.image %}
          <a href="{{ post.url }}" class="post-image-link">
            <img src="{{ post.data.image }}" alt="{{ post.data.title }}">
          </a>
          {% endif %}

          <div class="post-body">

            <div class="post-meta">
              <span class="category">{{ post.data.category or "VPN Tutorial" }}</span>
              <span class="read-time">◷ {{ post.data.readTime or "5 min read" }}</span>
            </div>

            <h3>
              <a href="{{ post.url }}">{{ post.data.title }}</a>
            </h3>

            {% if post.data.description %}
            <p>{{ post.data.description }}</p>
            {% endif %}

            <a href="{{ post.url }}" class="read-more">Read More →</a>

          </div>

        </article>
        {% endfor %}

      </div>
      {% else %}

      <div class="empty-state">
        <h3>No tutorials found</h3>
        <p>Add posts inside <code>src/posts/</code>.</p>
      </div>

      {% endif %}

    </div>
  </section>

  <section class="cta-section">
    <div class="cta-inner">

      <h2>Ready to Secure Your Digital Life?</h2>

      <p>
        Explore VPN setup tutorials, privacy guides, and server tips designed for everyday users.
      </p>

      <a class="hero-action-btn primary" href="/tutorials/">
        Explore More Tutorials
      </a>

    </div>
  </section>

</main>

<style>
footer,
.site-footer{
  display:none !important;
}

.vpnhub-page{
  min-height:100vh;
  color:var(--text-main);
  background:
    radial-gradient(circle at 20% 15%, rgba(168,85,247,.22), transparent 28%),
    linear-gradient(135deg,var(--site-bg) 0%,var(--site-bg-2) 45%,var(--site-bg-3) 100%);
}

.hero{
  padding:110px 20px 88px;
  text-align:center;
}

.hero-inner{
  max-width:1040px;
  margin:0 auto;
}

.hero-badge{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:10px 24px;
  margin-bottom:38px;
  border-radius:999px;
  border:1px solid var(--card-border);
  background:rgba(168,85,247,.16);
  color:var(--purple-soft);
  font-size:.95rem;
}

.hero h1{
  margin:0 0 24px;
  color:var(--text-main);
  font-size:4.05rem;
  line-height:1.05;
  font-weight:950;
  letter-spacing:-.045em;
}

.hero h1 span{
  color:var(--purple);
}

.hero p{
  max-width:820px;
  margin:0 auto 42px;
  color:var(--text-muted);
  font-size:1.25rem;
  line-height:1.8;
}

.hero-actions{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:18px;
  flex-wrap:wrap;
}

.hero-action-btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  min-width:170px;
  min-height:50px;
  padding:0 24px;
  border-radius:14px;
  font-size:1rem;
  font-weight:950;
  text-decoration:none;
  box-sizing:border-box;
  transition:.25s ease;
}

.hero-action-btn:hover{
  transform:translateY(-3px);
}

.hero-action-btn.primary{
  color:#ffffff;
  background:linear-gradient(90deg,#7c3aed,#2563eb);
  box-shadow:0 18px 45px rgba(124,58,237,.32);
}

.hero-action-btn.secondary{
  color:var(--text-main);
  background:rgba(255,255,255,.44);
  border:1px solid var(--card-border);
  box-shadow:0 14px 34px rgba(15,23,42,.08);
}

.hero-action-btn.glass{
  color:var(--text-main);
  background:var(--card-bg);
  border:1px solid var(--card-border);
  box-shadow:var(--shadow);
  backdrop-filter:blur(18px) saturate(180%);
  -webkit-backdrop-filter:blur(18px) saturate(180%);
}

body:not(.light-mode) .hero-action-btn.secondary{
  color:#ffffff;
  background:rgba(255,255,255,.14);
  border-color:rgba(255,255,255,.22);
}

body:not(.light-mode) .hero-action-btn.glass{
  color:#ffffff;
}

.section{
  padding:70px 20px;
}

.section-inner{
  max-width:1100px;
  margin:0 auto;
}

.section h2,
.cta-section h2{
  margin:0 0 42px;
  color:var(--text-main);
  text-align:center;
  font-size:2rem;
  line-height:1.18;
  font-weight:950;
  letter-spacing:-.035em;
}

.features-section{
  padding-top:54px;
}

.feature-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:26px;
}

.feature-card{
  min-height:170px;
  padding:28px 24px;
  border-radius:16px;
  background:var(--card-bg);
  border:1px solid var(--card-border);
  box-shadow:var(--shadow);
  transition:.25s ease;
  backdrop-filter:blur(22px) saturate(180%);
  -webkit-backdrop-filter:blur(22px) saturate(180%);
}

.feature-card:hover{
  transform:translateY(-6px);
}

.feature-icon{
  color:var(--purple-soft);
  font-size:2.5rem;
  line-height:1;
  margin-bottom:20px;
}

.feature-card h3{
  margin:0 0 12px;
  color:var(--text-main);
  font-size:1.05rem;
  line-height:1.3;
  font-weight:950;
}

.feature-card p{
  margin:0;
  color:var(--text-muted);
  font-size:.92rem;
  line-height:1.55;
}

.latest-section{
  padding-bottom:60px;
}

.post-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:30px;
}

.post-card{
  overflow:hidden;
  border-radius:18px;
  background:var(--card-bg);
  border:1px solid var(--card-border);
  box-shadow:var(--shadow);
  transition:.25s ease;
  backdrop-filter:blur(22px) saturate(180%);
  -webkit-backdrop-filter:blur(22px) saturate(180%);
}

.post-card:hover{
  transform:translateY(-7px);
}

.post-image-link{
  display:block;
  overflow:hidden;
}

.post-card img{
  width:100%;
  height:210px;
  display:block;
  object-fit:cover;
  transition:.35s ease;
}

.post-card:hover img{
  transform:scale(1.04);
}

.post-body{
  padding:22px;
}

.post-meta{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
  margin-bottom:16px;
}

.category{
  display:inline-flex;
  padding:6px 12px;
  border-radius:999px;
  background:rgba(124,58,237,.35);
  color:#d8b4fe;
  font-size:.72rem;
  font-weight:900;
}

body.light-mode .category{
  color:#7c3aed;
  background:rgba(124,58,237,.12);
}

.read-time{
  color:var(--text-muted);
  font-size:.76rem;
}

.post-card h3{
  margin:0 0 14px;
  font-size:1.2rem;
  line-height:1.36;
  font-weight:950;
}

.post-card h3 a{
  color:var(--text-main);
  text-decoration:none;
}

.post-card h3 a:hover{
  color:var(--purple-soft);
}

.post-card p{
  margin:0 0 18px;
  color:var(--text-muted);
  font-size:.9rem;
  line-height:1.55;
}

.read-more{
  color:var(--purple-soft);
  text-decoration:none;
  font-size:.9rem;
  font-weight:900;
}

.empty-state{
  max-width:620px;
  margin:0 auto;
  padding:34px;
  border-radius:20px;
  text-align:center;
  background:var(--card-bg);
  border:1px solid var(--card-border);
  box-shadow:var(--shadow);
}

.empty-state h3{
  margin:0 0 12px;
  color:var(--text-main);
}

.empty-state p{
  margin:0;
  color:var(--text-muted);
}

.empty-state code{
  padding:3px 7px;
  border-radius:7px;
  background:rgba(15,23,42,.75);
  color:#d8b4fe;
}

.cta-section{
  padding:90px 20px 115px;
  text-align:center;
}

.cta-inner{
  max-width:800px;
  margin:0 auto;
}

.cta-section h2{
  margin-bottom:22px;
}

.cta-section p{
  margin:0 auto 28px;
  color:var(--text-muted);
  font-size:1.05rem;
  line-height:1.7;
}

@media(max-width:1000px){
  .hero h1{
    font-size:3.35rem;
  }

  .hero p{
    font-size:1.15rem;
  }

  .feature-grid{
    grid-template-columns:repeat(2,1fr);
  }

  .post-grid{
    grid-template-columns:repeat(2,1fr);
  }
}

@media(max-width:768px){
  .hero{
    padding:58px 18px 58px;
  }

  .hero-badge{
    margin-bottom:26px;
    padding:9px 16px;
    font-size:.78rem;
  }

  .hero h1{
    font-size:2.25rem;
    line-height:1.12;
    margin-bottom:20px;
  }

  .hero p{
    font-size:1rem;
    line-height:1.72;
    margin-bottom:30px;
  }

  .hero-actions{
    flex-direction:column;
    gap:12px;
  }

  .hero-action-btn{
    width:100%;
    max-width:310px;
    min-height:50px;
    font-size:.95rem;
  }

  .section{
    padding:52px 18px;
  }

  .section h2,
  .cta-section h2{
    font-size:1.8rem;
  }

  .feature-grid,
  .post-grid{
    grid-template-columns:1fr;
  }

  .feature-card{
    min-height:auto;
  }

  .post-card img{
    height:210px;
  }
}

@media(max-width:420px){
  .hero h1{
    font-size:2.05rem;
  }

  .post-body{
    padding:20px;
  }
}
</style>
