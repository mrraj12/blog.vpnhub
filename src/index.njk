---
layout: base.njk
title: VPNHUB - Tutorials & VPN Guides
description: VPN tutorials, privacy guides, server tips, and video lessons.
---

{% set posts = collections.posts | reverse %}

<main class="vpnhub-page">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">

      <h1>
        Your Privacy,
        <span>Protected</span>
      </h1>

      <p>
        Discover the latest insights on digital privacy, security, and how VPNs
        are reshaping the way we browse the internet safely.
      </p>

      <a class="primary-btn" href="/tutorials/">
        Start Your Secure Journey
      </a>

    </div>
  </section>

  <!-- Features -->
  <section class="section features-section">
    <div class="section-inner">

      <h2>Why Choose VPNHUB?</h2>

      <div class="feature-grid">

        <article class="feature-card">
          <div class="feature-icon">♢</div>
          <h3>Military-Grade Encryption</h3>
          <p>AES-256 encryption protects your data from hackers and surveillance</p>
        </article>

        <article class="feature-card">
          <div class="feature-icon">ϟ</div>
          <h3>Lightning Fast Speeds</h3>
          <p>Optimized servers ensure minimal impact on your browsing experience</p>
        </article>

        <article class="feature-card">
          <div class="feature-icon">◎</div>
          <h3>Global Server Network</h3>
          <p>Access content from 50+ countries with our worldwide server locations</p>
        </article>

        <article class="feature-card">
          <div class="feature-icon">▢</div>
          <h3>Zero-Log Policy</h3>
          <p>We never track, collect, or share your private data</p>
        </article>

      </div>

    </div>
  </section>

  <!-- Latest Insights -->
  <section class="section latest-section">
    <div class="section-inner">

      <h2>Latest Insights</h2>

      <div class="post-grid">

        {% for post in posts %}
        {% if loop.index0 < 3 %}
        <article class="post-card">

          {% if post.data.image %}
          <img src="{{ post.data.image }}" alt="{{ post.data.title }}">
          {% endif %}

          <div class="post-body">

            <div class="post-meta">
              <span class="category">{{ post.data.category or "Security" }}</span>
              <span class="read-time">◷ {{ post.data.readTime or "5 min read" }}</span>
            </div>

            <h3>{{ post.data.title }}</h3>

            <p>{{ post.data.description }}</p>

            <a href="{{ post.url }}" class="read-more">Read More →</a>

          </div>

        </article>
        {% endif %}
        {% endfor %}

      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-inner">

      <h2>Ready to Secure Your Digital Life?</h2>

      <p>
        Join thousands of users who trust VPNHUB for their online privacy and security needs.
      </p>

    </div>
  </section>

</main>

<style>
/* Hide footer from base.njk on this homepage */
footer,
.site-footer{
  display:none !important;
}

.vpnhub-page{
  min-height:100vh;
  color:#ffffff;
  background:
    radial-gradient(circle at 20% 15%, rgba(168,85,247,.22), transparent 28%),
    linear-gradient(135deg,#111827 0%,#4c1d95 45%,#1e3a8a 100%);
}

/* Hero */
.hero{
  padding:105px 20px 75px;
  text-align:center;
}

.hero-inner{
  max-width:760px;
  margin:0 auto;
}

.hero h1{
  margin:0 0 18px;
  color:#ffffff;
  font-size:3.7rem;
  line-height:1.08;
  font-weight:950;
  letter-spacing:-.045em;
}

.hero h1 span{
  color:#a855f7;
}

.hero p{
  margin:0 auto 32px;
  color:#d1d5db;
  font-size:1.18rem;
  line-height:1.55;
}

.primary-btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  border:0;
  border-radius:9px;
  padding:16px 34px;
  color:#ffffff;
  background:linear-gradient(90deg,#7c3aed,#2563eb);
  font-size:.95rem;
  font-weight:900;
  text-decoration:none;
  cursor:pointer;
  box-shadow:0 14px 35px rgba(124,58,237,.28);
}

/* Sections */
.section{
  padding:70px 20px;
}

.section-inner{
  max-width:1100px;
  margin:0 auto;
}

.section h2,
.cta-section h2{
  margin:0 0 42px;
  color:#ffffff;
  text-align:center;
  font-size:2rem;
  line-height:1.18;
  font-weight:950;
  letter-spacing:-.035em;
}

/* Features */
.features-section{
  padding-top:60px;
}

.feature-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:26px;
}

.feature-card{
  min-height:170px;
  padding:28px 24px;
  border-radius:12px;
  background:rgba(31,41,55,.62);
  box-shadow:0 18px 45px rgba(0,0,0,.22);
  transition:.25s ease;
}

.feature-card:hover{
  transform:translateY(-6px);
}

.feature-icon{
  color:#c084fc;
  font-size:2.7rem;
  line-height:1;
  margin-bottom:22px;
}

.feature-card h3{
  margin:0 0 12px;
  color:#ffffff;
  font-size:1.05rem;
  line-height:1.3;
  font-weight:950;
}

.feature-card p{
  margin:0;
  color:#d1d5db;
  font-size:.92rem;
  line-height:1.55;
}

/* Latest Insights Cards */
.latest-section{
  padding-bottom:60px;
}

.post-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:30px;
}

.post-card{
  overflow:hidden;
  border-radius:10px;
  background:#1f2937;
  box-shadow:0 18px 45px rgba(0,0,0,.22);
  transition:.25s ease;
}

.post-card:hover{
  transform:translateY(-7px);
}

.post-card img{
  width:100%;
  height:190px;
  display:block;
  object-fit:cover;
}

.post-body{
  padding:22px;
}

.post-meta{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
  margin-bottom:16px;
}

.category{
  display:inline-flex;
  padding:6px 12px;
  border-radius:999px;
  background:rgba(124,58,237,.35);
  color:#d8b4fe;
  font-size:.72rem;
  font-weight:900;
}

.read-time{
  color:#9ca3af;
  font-size:.76rem;
}

.post-card h3{
  margin:0 0 14px;
  color:#ffffff;
  font-size:1.2rem;
  line-height:1.36;
  font-weight:950;
}

.post-card p{
  margin:0 0 18px;
  color:#d1d5db;
  font-size:.9rem;
  line-height:1.55;
}

.read-more{
  color:#c084fc;
  text-decoration:none;
  font-size:.9rem;
  font-weight:900;
}

/* CTA */
.cta-section{
  padding:95px 20px 120px;
  text-align:center;
}

.cta-inner{
  max-width:800px;
  margin:0 auto;
}

.cta-section h2{
  margin-bottom:22px;
}

.cta-section p{
  margin:0;
  color:#d1d5db;
  font-size:1.05rem;
  line-height:1.7;
}

/* Tablet */
@media(max-width:1000px){
  .feature-grid{
    grid-template-columns:repeat(2,1fr);
  }

  .post-grid{
    grid-template-columns:repeat(2,1fr);
  }
}

/* Mobile */
@media(max-width:768px){
  .hero{
    padding:82px 18px 54px;
  }

  .hero h1{
    font-size:2.6rem;
  }

  .hero p{
    font-size:1.02rem;
  }

  .section{
    padding:54px 18px;
  }

  .section h2,
  .cta-section h2{
    font-size:1.85rem;
  }

  .feature-grid,
  .post-grid{
    grid-template-columns:1fr;
  }

  .feature-card{
    min-height:auto;
  }

  .post-card img{
    height:210px;
  }
}

@media(max-width:420px){
  .hero h1{
    font-size:2.25rem;
  }

  .primary-btn{
    width:100%;
    box-sizing:border-box;
  }

  .post-body{
    padding:20px;
  }
}
</style>
