  max-width:750px;
  margin:0 auto 30px;
  color:#d1d5db;
  font-size:1.3rem;
  line-height:1.8;
}

.actions{
  display:flex;
  justify-content:center;
  gap:15px;
  flex-wrap:wrap;
}

.btn{
  background:linear-gradient(
    90deg,
    #7c3aed,
    #2563eb
  );
  color:#fff;
  padding:14px 28px;
  border-radius:12px;
  text-decoration:none;
  font-weight:600;
}

.btn.secondary{
  background:#ffffff20;
  border:1px solid #ffffff30;
}

.section{
  padding:70px 20px;
}

.section-inner{
  max-width:1200px;
  margin:auto;
}

.section h2{
  text-align:center;
  font-size:2.5rem;
  margin-bottom:10px;
}

