---
layout: base.njk
title: VPNHUB - Tutorials & VPN Guides
description: VPN tutorials, privacy guides, server tips, and video lessons.
---

<header class="hero">
  <div class="hero-inner">

    <span class="badge">
      VPN Security • Privacy Protection • Online Freedom
    </span>

    <h1>
      Your Privacy,
      <span class="highlight">Protected</span>
    </h1>

    <p>
      Discover the latest insights on digital privacy, VPN security,
      online freedom, streaming access, and server management with
      step-by-step tutorials from VPNHUB.
    </p>

    <div class="actions">
      <a class="btn" href="/tutorials/">View Tutorials</a>
      <a class="btn secondary" href="/videos/">Watch Videos</a>
    </div>

  </div>
</header>

<!-- TOP 3 TUTORIALS -->

<section class="section">
  <div class="section-inner">

    <h2>Top Tutorials</h2>
    <p class="lead">
      Featured VPN guides and tutorials from VPNHUB.
    </p>

    <div class="grid top-tutorials">

      {% for post in collections.posts | reverse | slice(0,3) %}
      <article class="post-card">

        {% if post.data.image %}
        <img src="{{ post.data.image }}" alt="{{ post.data.title }}">
        {% endif %}

        <div class="meta">
          {{ post.data.date }} · {{ post.data.category }}
        </div>

        <h3>{{ post.data.title }}</h3>

        <p>{{ post.data.description }}</p>

        <a class="read-more" href="{{ post.url }}">
          Read More →
        </a>

      </article>
      {% endfor %}

    </div>

  </div>
</section>

<!-- LATEST TUTORIALS -->

<section class="section">
  <div class="section-inner">

    <h2>Latest Tutorials</h2>

    <p class="lead">
      Fresh guides and blog posts from VPNHUB.
    </p>

    <div class="grid">

      {% for post in collections.posts | reverse | slice(0,6) %}
      <article class="post-card">

        {% if post.data.image %}
        <img src="{{ post.data.image }}" alt="{{ post.data.title }}">
        {% endif %}

        <div class="meta">
          {{ post.data.date }} · {{ post.data.category }}
        </div>

        <h3>{{ post.data.title }}</h3>

        <p>{{ post.data.description }}</p>

        <a class="read-more" href="{{ post.url }}">
          Read More →
        </a>

      </article>
      {% endfor %}

    </div>

  </div>
</section>

<!-- FEATURES -->

<section class="section">
  <div class="section-inner grid">

    <div class="card">
      <h3>🔒 VPN Security</h3>
      <p>
        Learn how VPN encryption protects your privacy and secures your online activities.
      </p>
    </div>

    <div class="card">
      <h3>🖼 Images & Screenshots</h3>
      <p>
        Upload screenshots and tutorial images directly through the CMS editor.
      </p>
    </div>

    <div class="card">
      <h3>🎥 Video Tutorials</h3>
      <p>
        Embed YouTube videos and create complete visual learning guides.
      </p>
    </div>

    <div class="card">
      <h3>🌎 Server Guides</h3>
      <p>
        Learn V2Ray, Clash, Sing-box, VPS setup, and VPN server management.
      </p>
    </div>

  </div>
</section>

<style>
