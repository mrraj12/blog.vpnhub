  top:0;
  z-index:1000;
  background:var(--header-bg);
  border-bottom:1px solid var(--border);
  backdrop-filter:blur(16px);
}

.nav-inner{
  max-width:1200px;
  min-height:78px;
  margin:0 auto;
  padding:0 22px;
  display:flex;
  align-items:center;
  justify-content:space-between;
}

.brand{
  display:flex;
  align-items:center;
  gap:10px;
  color:var(--text);
  text-decoration:none;
  font-size:1.55rem;
  font-weight:900;
  letter-spacing:-.03em;
}

.brand-icon{
  color:#c084fc;
  font-size:2rem;
  line-height:1;
}

.desktop-nav{
  display:flex;
